---
const year = new Date().getFullYear();
---

<footer class="footer-root mt-auto">
    <div class="w-full max-w-7xl mx-auto px-6 sm:px-8 pt-12 pb-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12 items-start">
            <!-- Hours + Directions Column -->
            <div>
                <h3 class="eyebrow mb-5">Çalışma Saatleri</h3>
                <ul class="space-y-2.5 mb-6">
                    <li class="footer-hours-row">
                        <span class="footer-hours-day">Pazartesi – Cuma</span>
                        <span class="footer-hours-time">09:00 – 18:00</span>
                    </li>
                    <li class="footer-hours-row">
                        <span class="footer-hours-day">Cumartesi – Pazar</span>
                        <span class="footer-hours-closed">Kapalı</span>
                    </li>
                </ul>
                <a
                    href="https://www.google.com/maps/dir/?api=1&destination=38.456222,27.118806"
                    target="_blank"
                    rel="noopener"
                    class="footer-directions cursor-pointer"
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                    </svg>
                    Yol Tarifi Al
                </a>
            </div>

            <!-- Links Column -->
            <div>
                <h3 class="eyebrow mb-5">Hızlı Erişim</h3>
                <ul class="space-y-3">
                    <li><a href="/calisma-alanlarimiz" class="footer-link">Çalışma Alanlarımız</a></li>
                    <li><a href="/hesaplama-araclari" class="footer-link">Hesaplama Araçları</a></li>
                    <li><a href="/blog" class="footer-link">Blog</a></li>
                    <li><a href="/iletisim" class="footer-link">İletişim</a></li>
                </ul>
            </div>

            <!-- Contact Column -->
            <div>
                <h3 class="eyebrow mb-5">Adres ve İletişim Bilgileri</h3>
                <ul class="space-y-4">
                    <li class="flex items-start gap-3">
                        <svg class="w-4 h-4 mt-1 shrink-0" style="color: var(--brand);" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        <span class="footer-text">1690 Sk. Doktorlar İş Hanı No: 1<br/>Daire: 601 Karşıyaka / İzmir</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <svg class="w-4 h-4 shrink-0" style="color: var(--brand);" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                        </svg>
                        <a href="tel:+905077247735" class="footer-link">0 (507) 724 77 35</a>
                    </li>
                    <li class="flex items-center gap-3">
                        <svg class="w-4 h-4 shrink-0" style="color: var(--brand);" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                        <a href="mailto:info@discilaw.com" class="footer-link">info@discilaw.com</a>
                    </li>
                </ul>
            </div>
        </div>

        <hr class="footer-divider my-8" />

        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex gap-5 text-sm">
                <a href="/yasal/gizlilik-politikasi" class="footer-fine">Gizlilik Politikası</a>
                <span class="footer-fine-sep">·</span>
                <a href="/yasal/aydinlatma-metni" class="footer-fine">Aydınlatma Metni</a>
            </div>
            <div class="footer-fine">
                © {year} Dişçi Hukuk Bürosu. Tüm Hakları Saklıdır.
            </div>
        </div>
    </div>
</footer>

<style>
    .footer-root {
        background: var(--bg-elevated);
        border-top: 1px solid var(--border-soft);
    }
    .footer-link {
        font-family: var(--font-sans);
        font-weight: 400;
        font-size: 0.9375rem;
        color: var(--ink-default);
        transition: color 200ms ease;
    }
    .footer-link:hover { color: var(--brand-deep); }

    .footer-text {
        font-family: var(--font-sans);
        font-weight: 400;
        font-size: 0.9375rem;
        color: var(--ink-default);
        line-height: 1.55;
    }

    .footer-divider {
        border: none;
        border-top: 1px solid var(--border-soft);
    }

    .footer-fine {
        font-family: var(--font-sans);
        font-weight: 400;
        font-size: 0.75rem;
        color: var(--ink-muted);
        transition: color 200ms ease;
    }
    a.footer-fine:hover { color: var(--brand-deep); }

    .footer-fine-sep {
        color: var(--ink-faint);
        font-size: 0.75rem;
    }

    .footer-hours-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        font-family: var(--font-sans);
        font-size: 0.9375rem;
    }
    .footer-hours-day {
        color: var(--ink-default);
    }
    .footer-hours-time {
        color: var(--ink-strong);
        font-weight: 500;
        font-variant-numeric: tabular-nums;
    }
    .footer-hours-closed {
        color: var(--ink-muted);
        font-style: italic;
        font-family: var(--font-display);
        font-weight: 400;
    }

    .footer-directions {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 0.875rem;
        color: var(--brand-deep);
        border-bottom: 1px solid currentColor;
        padding-bottom: 1px;
        transition: color 200ms ease;
    }
    .footer-directions:hover { color: var(--ink-strong); }
    .footer-directions svg { transition: transform 220ms ease; }
    .footer-directions:hover svg { transform: translateX(3px); }
</style>
