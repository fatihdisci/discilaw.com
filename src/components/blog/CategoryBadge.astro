---
interface Props {
  label: string;
  interactive?: boolean;
}

const { label, interactive = false } = Astro.props;
---

<span class={`category-badge${interactive ? ' is-interactive' : ''}`}>
  {label}
</span>

<style>
  .category-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.625rem;
    border-radius: var(--radius-pill);
    background: var(--brand-soft);
    color: var(--brand-deep);
    border: 1px solid var(--border-soft);
    line-height: 1;
  }
  .category-badge.is-interactive {
    transition: background 200ms ease, color 200ms ease, border-color 200ms ease;
    cursor: pointer;
  }
  .category-badge.is-interactive:hover {
    background: rgba(122, 135, 88, 0.22);
    color: var(--ink-strong);
    border-color: var(--brand);
  }
</style>
