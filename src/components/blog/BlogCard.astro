---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  post: any;
}

const { post } = Astro.props;
const image = post.data.image;
---

<article class="rounded-2xl overflow-hidden border transition-colors flex flex-col h-full" style="background: var(--card-bg); border-color: var(--border);">
  {image ? (
    <img src={image} alt={post.data.title} width="800" height="450" loading="lazy" decoding="async" class="w-full h-48 object-cover opacity-80 hover:opacity-100 transition-opacity" />
  ) : (
    <div class="w-full h-48 flex items-center justify-center" style="background: var(--bg-3);">
      <span class="text-4xl">⚖️</span>
    </div>
  )}
  <div class="p-6 flex-grow flex flex-col">
    <div class="flex flex-wrap gap-2 mb-4 items-center">
      <CategoryBadge label={post.data.category || 'Genel'} />
      <time class="text-xs" style="color: var(--text-3);">
        {post.data.pubDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
    <h3 class="text-xl font-bold mb-3 line-clamp-2 font-display" style="color: var(--text);">
      <a href={`/blog/${post.slug}`} class="hover:text-gold-500 transition-colors">{post.data.title}</a>
    </h3>
    <p class="text-sm mb-6 line-clamp-3" style="color: var(--text-2);">{post.data.description}</p>
    <div class="mt-auto pt-4 border-t" style="border-color: var(--border);">
      <a href={`/blog/${post.slug}`} class="hover:text-gold-500 text-sm font-medium transition-colors" style="color: var(--text);">Devamını Oku &rarr;</a>
    </div>
  </div>
</article>
