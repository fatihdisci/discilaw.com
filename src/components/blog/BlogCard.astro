---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  post: any;
}

const { post } = Astro.props;
const image = post.data.image;
---

<article class="blog-card">
  {image ? (
    <a href={`/blog/${post.slug}`} class="blog-card-image-link cursor-pointer">
      <img src={image} alt={post.data.title} width="800" height="450" loading="lazy" decoding="async" class="blog-card-image" />
    </a>
  ) : (
    <a href={`/blog/${post.slug}`} class="blog-card-image-link blog-card-image-fallback cursor-pointer" aria-label={post.data.title}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M16 16l3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1z"/>
        <path d="M2 16l3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1z"/>
        <path d="M7 21h10"/>
        <path d="M12 3v18"/>
        <path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>
      </svg>
    </a>
  )}
  <div class="blog-card-body">
    <div class="blog-card-meta">
      <CategoryBadge label={post.data.category || 'Genel'} />
      <time class="blog-card-date">
        {post.data.pubDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
    <h3 class="blog-card-title">
      <a href={`/blog/${post.slug}`} class="cursor-pointer">{post.data.title}</a>
    </h3>
    <p class="blog-card-desc">{post.data.description}</p>
    <div class="blog-card-footer">
      <a href={`/blog/${post.slug}`} class="blog-card-readmore cursor-pointer">
        Devamını Oku
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--bg-base);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 280ms cubic-bezier(.4,0,.2,1),
                box-shadow 280ms cubic-bezier(.4,0,.2,1),
                border-color 280ms ease;
  }
  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--border);
  }

  .blog-card-image-link {
    display: block;
    overflow: hidden;
  }
  .blog-card-image {
    width: 100%;
    height: 12rem;
    object-fit: cover;
    transition: transform 600ms ease, opacity 280ms ease;
    opacity: 0.92;
  }
  .blog-card:hover .blog-card-image {
    opacity: 1;
    transform: scale(1.04);
  }

  .blog-card-image-fallback {
    height: 12rem;
    background: var(--brand-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-deep);
  }
  .blog-card-image-fallback svg {
    width: 56px;
    height: 56px;
    opacity: 0.85;
  }

  .blog-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .blog-card-date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
  }

  .blog-card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.25rem;
    line-height: 1.25;
    letter-spacing: -0.018em;
    color: var(--ink-strong);
    margin-bottom: 0.65rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-title a {
    color: inherit;
    transition: color 200ms ease;
  }
  .blog-card-title a:hover { color: var(--brand-deep); }

  .blog-card-desc {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-default);
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--border-soft);
  }

  .blog-card-readmore {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--brand-deep);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: color 200ms ease, border-color 200ms ease;
  }
  .blog-card-readmore:hover {
    color: var(--ink-strong);
    border-bottom-color: currentColor;
  }
  .blog-card-readmore svg {
    transition: transform 220ms ease;
  }
  .blog-card-readmore:hover svg {
    transform: translateX(3px);
  }
</style>
