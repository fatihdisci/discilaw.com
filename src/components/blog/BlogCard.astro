---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  post: any;
}

const { post } = Astro.props;
const image = post.data.image;
---

<article class="bg-slate-950 rounded-2xl overflow-hidden border border-slate-800 hover:border-slate-700 transition-colors flex flex-col h-full">
  {image ? (
    <img src={image} alt={post.data.title} width="800" height="450" loading="lazy" decoding="async" class="w-full h-48 object-cover opacity-80 hover:opacity-100 transition-opacity" />
  ) : (
    <div class="w-full h-48 bg-gradient-to-br from-slate-800 to-slate-900 flex items-center justify-center">
      <span class="text-4xl">⚖️</span>
    </div>
  )}
  <div class="p-6 flex-grow flex flex-col">
    <div class="flex flex-wrap gap-2 mb-4 items-center">
      <CategoryBadge label={post.data.category || 'Genel'} />
      <time class="text-xs text-slate-500 self-center">
        {post.data.pubDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
    <h3 class="text-xl font-bold text-white mb-3 line-clamp-2 font-serif">
      <a href={`/blog/${post.slug}`} class="hover:text-gold-500 transition-colors">{post.data.title}</a>
    </h3>
    <p class="text-slate-400 text-sm mb-6 line-clamp-3">{post.data.description}</p>
    <div class="mt-auto pt-4 border-t border-slate-900">
      <a href={`/blog/${post.slug}`} class="text-white hover:text-gold-500 text-sm font-medium transition-colors">Devamını Oku &rarr;</a>
    </div>
  </div>
</article>
