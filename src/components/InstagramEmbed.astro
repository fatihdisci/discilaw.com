---
interface Props {
  url: string;
}

const { url } = Astro.props;

// Instagram URL'sinden /embed/ versiyonunu oluştur
const cleanUrl = url.replace(/\/$/, '');
const embedUrl = cleanUrl.includes('/embed') ? cleanUrl : `${cleanUrl}/embed`;
---

<div class="instagram-embed-wrapper my-8">
  <h3 class="text-lg font-display mb-4" style="color: var(--text-2);">Bu yazıyla ilgili Instagram paylaşımımız</h3>
  <div class="rounded-2xl overflow-hidden border max-w-[540px]" style="border-color: var(--border);">
    <iframe
      src={embedUrl}
      width="540"
      height="720"
      frameborder="0"
      scrolling="no"
      allowtransparency="true"
      class="w-full"
      loading="lazy"
      title="Instagram gönderisi"
    ></iframe>
  </div>
</div>
