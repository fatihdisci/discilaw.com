---
interface Props {
  url: string;
}

const { url } = Astro.props;

// Query string'i temizle (igsh, utm ve diğer tracking parametreleri embed'de çalışmaz)
const cleanedUrl = url.split('?')[0].replace(/\/$/, '');
// Instagram URL'sinden /embed/ versiyonunu oluştur
const embedUrl = cleanedUrl.includes('/embed') ? cleanedUrl : `${cleanedUrl}/embed`;
---

<div class="instagram-embed-wrapper my-8">
  <h3 class="ig-embed-title">Bu yazıyla ilgili Instagram paylaşımımız</h3>
  <div class="ig-embed-frame">
    <iframe
      src={embedUrl}
      width="540"
      height="720"
      frameborder="0"
      scrolling="no"
      allowtransparency="true"
      class="w-full"
      loading="lazy"
      title="Instagram gönderisi"
    ></iframe>
  </div>
</div>

<style>
  .ig-embed-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: 1.125rem;
    letter-spacing: -0.015em;
    color: var(--ink-default);
    margin-bottom: 1rem;
  }
  .ig-embed-frame {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 540px;
  }
</style>
