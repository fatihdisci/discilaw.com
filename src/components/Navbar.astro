---
const links = [
  { name: 'Anasayfa', href: '/' },
  { name: 'Hakkımızda', href: '/hakkimizda' },
  { name: 'Çalışma Alanlarımız', href: '/calisma-alanlarimiz' },
  { name: 'Blog', href: '/blog' },
  { name: 'SSS', href: '/sss' },
];

const hesaplamaAraclari = [
  { name: 'Kıdem Tazminatı Hesaplama', href: '/hesaplama-araclari/kidem-tazminati' },
  { name: 'İhbar Tazminatı Hesaplama', href: '/hesaplama-araclari/ihbar-tazminati' },
  { name: 'Avukatlık Ücreti Hesaplama', href: '/hesaplama-araclari/avukatlik-ucreti' },
];
---

<nav class="nav-root fixed w-full z-50 top-0 start-0 backdrop-blur-md">
  <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-between py-0 px-4">
    <a href="/" class="flex items-center gap-3 group cursor-pointer -my-4 sm:-my-5 md:-my-6">
      <img src="/logo.png" alt="Dişçi Hukuk Bürosu" class="h-40 sm:h-48 md:h-56 w-auto object-contain transition-transform duration-300 group-hover:scale-[1.03]" />
    </a>

    <button id="mobile-menu-toggle" type="button"
      class="inline-flex items-center p-2 w-10 h-10 justify-center rounded-md md:hidden cursor-pointer transition-colors"
      style="color: var(--ink-default);"
      aria-controls="navbar-default" aria-expanded="false">
      <span class="sr-only">Menüyü Aç</span>
      <svg id="icon-menu" class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M1 1h15M1 7h15M1 13h15"/>
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 6l12 12M6 18L18 6"/>
      </svg>
    </button>

    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul class="nav-list flex flex-col p-4 md:p-0 mt-4 rounded-2xl md:flex-row md:items-center md:gap-7 md:mt-0 md:!bg-transparent">
        {links.map((link) => (
          <li>
            <a href={link.href} class="nav-link block py-2 px-3 md:p-0 cursor-pointer">{link.name}</a>
          </li>
        ))}

        <li class="relative group/dropdown nav-dropdown-item">
          <div class="md:hidden">
            <button id="mobile-tools-toggle" type="button"
              class="nav-link nav-mobile-tools-btn w-full flex items-center justify-between py-2 px-3 cursor-pointer"
              aria-controls="mobile-tools-panel" aria-expanded="false">
              <span>Hesaplama Araçları</span>
              <svg id="mobile-tools-chevron" class="w-3.5 h-3.5 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
          </div>
          <a href="/hesaplama-araclari" class="nav-link nav-desktop-tools-link hidden md:flex items-center gap-1.5 md:p-0 cursor-pointer">
            Hesaplama Araçları
            <svg class="w-3 h-3 transition-transform duration-200 group-hover/dropdown:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>

          <div id="mobile-tools-panel" class="nav-dropdown-wrap hidden md:block md:absolute md:left-1/2 md:-translate-x-1/2 md:top-full md:pt-3 md:opacity-0 md:invisible group-hover/dropdown:md:opacity-100 group-hover/dropdown:md:visible transition-all duration-200">
            <ul class="dropdown-panel md:rounded-2xl md:py-2 md:min-w-[280px] mt-2 md:mt-0 pl-4 md:pl-0">
              {hesaplamaAraclari.map((tool) => (
                <li>
                  <a href={tool.href} class="dropdown-link block py-2.5 px-4 text-sm md:text-[15px] cursor-pointer">
                    {tool.name}
                  </a>
                </li>
              ))}
              <li class="dropdown-divider mt-2 pt-2">
                <a href="/hesaplama-araclari" class="dropdown-link-primary block py-2 px-4 text-sm cursor-pointer">
                  Tüm Araçları Gör
                  <svg class="inline w-3.5 h-3.5 ml-1 -mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </li>
            </ul>
          </div>
        </li>

        <li class="md:ml-2 mt-3 md:mt-0">
          <a href="/iletisim" class="nav-cta inline-flex items-center justify-center cursor-pointer w-full md:w-auto">
            İletişim
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<style>
  .nav-root {
    background: rgba(244, 245, 240, 0.78);
    border-bottom: 1px solid var(--border-soft);
  }

  .nav-list {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
  }
  @media (min-width: 768px) {
    .nav-list {
      background: transparent;
      border: none;
    }
  }

  .nav-link {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--ink-default);
    letter-spacing: -0.005em;
    transition: color 200ms ease;
  }
  .nav-link:hover { color: var(--brand-deep); }

  .nav-mobile-tools-btn {
    background: transparent;
    border: none;
    text-align: left;
  }
  .nav-mobile-tools-btn[aria-expanded="true"] {
    color: var(--brand-deep);
  }
  .nav-mobile-tools-btn[aria-expanded="true"] #mobile-tools-chevron {
    transform: rotate(180deg);
  }

  .nav-cta {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: 0.01em;
    background: var(--ink-strong);
    color: var(--bg-base);
    padding: 12px 22px;
    border-radius: var(--radius-pill);
    transition: background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .nav-cta:hover {
    background: var(--brand-deep);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .dropdown-panel {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
  }
  @media (min-width: 768px) {
    .dropdown-panel { box-shadow: var(--shadow-md); }
  }
  .dropdown-link {
    color: var(--ink-default);
    font-family: var(--font-sans);
    font-weight: 400;
    transition: color 200ms ease, background 200ms ease;
  }
  .dropdown-link:hover {
    color: var(--brand-deep);
    background: var(--brand-soft);
  }
  .dropdown-divider {
    border-top: 1px solid var(--border-soft);
  }
  .dropdown-link-primary {
    color: var(--brand-deep);
    font-family: var(--font-sans);
    font-weight: 500;
    transition: color 200ms ease;
  }
  .dropdown-link-primary:hover { color: var(--ink-strong); }
</style>

<script>
  const toggleButton = document.getElementById('mobile-menu-toggle');
  const navbarDefault = document.getElementById('navbar-default');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  if (toggleButton && navbarDefault) {
    toggleButton.addEventListener('click', () => {
      const isHidden = navbarDefault.classList.toggle('hidden');
      toggleButton.setAttribute('aria-expanded', String(!isHidden));
      iconMenu?.classList.toggle('hidden', !isHidden);
      iconClose?.classList.toggle('hidden', isHidden);
    });
  }

  const toolsToggle = document.getElementById('mobile-tools-toggle');
  const toolsPanel = document.getElementById('mobile-tools-panel');

  if (toolsToggle && toolsPanel) {
    toolsToggle.addEventListener('click', () => {
      const isHidden = toolsPanel.classList.toggle('hidden');
      toolsToggle.setAttribute('aria-expanded', String(!isHidden));
    });
  }
</script>
