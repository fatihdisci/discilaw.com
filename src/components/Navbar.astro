---
const links = [
  { name: 'Anasayfa', href: '/' },
  { name: 'Çalışma Alanlarımız', href: '/calisma-alanlarimiz' },
  { name: 'Blog', href: '/blog' },
  { name: 'İletişim', href: '/iletisim' },
];

const hesaplamaAraclari = [
  { name: 'Kıdem Tazminatı Hesaplama', href: '/hesaplama-araclari/kidem-tazminati' },
  { name: 'İhbar Tazminatı Hesaplama', href: '/hesaplama-araclari/ihbar-tazminati' },
  { name: 'Avukatlık Ücreti Hesaplama', href: '/hesaplama-araclari/avukatlik-ucreti' },
];
---

<nav class="fixed w-full z-50 top-0 start-0 border-b border-[#2A2925] backdrop-blur-md"
     style="background: rgba(12,11,9,0.97);">
  <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-between py-4 px-4 sm:py-6 md:py-8">
    <a href="/" class="flex items-center gap-3 group">
      <img src="/logo.png" alt="Dişçi Hukuk Bürosu" class="h-24 sm:h-28 md:h-36 w-auto object-contain transition-transform group-hover:scale-105" />
    </a>
    <button id="mobile-menu-toggle" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-300 rounded-lg md:hidden focus:outline-none focus:ring-2 focus:ring-gold-500/50 transition-colors" aria-controls="navbar-default" aria-expanded="false">
      <span class="sr-only">Menüyü Aç</span>
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
      </svg>
    </button>
    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-[#2A2925] rounded-lg md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 bg-[#1A1916] md:!bg-transparent">
        {links.slice(0, 3).map((link) => (
          <li>
            <a href={link.href}
               class="block py-2 px-3 text-gray-300 rounded md:hover:bg-transparent md:border-0 md:p-0 transition-colors duration-200 hover:text-white">{link.name}</a>
          </li>
        ))}

        <li class="relative group/dropdown">
          <a href="/hesaplama-araclari"
             class="flex items-center gap-1 py-2 px-3 text-gray-300 rounded md:hover:bg-transparent md:border-0 md:p-0 transition-colors duration-200 hover:text-white">
            Hesaplama Araçları
            <svg class="w-3 h-3 ml-1 transition-transform duration-200 group-hover/dropdown:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
          <div class="md:absolute md:left-1/2 md:-translate-x-1/2 md:top-full md:pt-2 md:opacity-0 md:invisible group-hover/dropdown:md:opacity-100 group-hover/dropdown:md:visible transition-all duration-200">
            <ul class="md:border md:border-[#2A2925] md:rounded-xl md:shadow-xl md:py-2 md:min-w-[260px] mt-2 md:mt-0 pl-4 md:pl-0 bg-[#1A1916]">
              {hesaplamaAraclari.map((tool) => (
                <li>
                  <a href={tool.href}
                     class="block py-2 px-4 text-gray-300 hover:text-gold-500 transition-colors duration-200 text-sm md:text-base">
                    {tool.name}
                  </a>
                </li>
              ))}
              <li class="border-t border-[#2A2925] mt-2 pt-2">
                <a href="/hesaplama-araclari" class="block py-2 px-4 text-gold-500 transition-colors duration-200 text-sm font-medium">
                  Tüm Araçları Gör →
                </a>
              </li>
            </ul>
          </div>
        </li>

        {links.slice(3).map((link) => (
          <li>
            <a href={link.href}
               class="block py-2 px-3 text-gray-300 rounded md:hover:bg-transparent md:border-0 md:p-0 transition-colors duration-200 hover:text-white">{link.name}</a>
          </li>
        ))}
        <li class="flex items-center">
          <button id="theme-toggle"
            class="flex items-center gap-2 px-3 py-2 rounded-lg border border-[#2A2925] cursor-pointer transition-all duration-300 hover:border-gold-500/50 bg-[#131210]"
            aria-label="Temayı değiştir">
            <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" class="text-gold-500" style="fill: currentColor;">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
            <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" class="hidden text-gold-500" style="fill: currentColor;">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3" stroke="currentColor" stroke-width="2"/>
              <line x1="12" y1="21" x2="12" y2="23" stroke="currentColor" stroke-width="2"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" stroke="currentColor" stroke-width="2"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" stroke="currentColor" stroke-width="2"/>
              <line x1="1" y1="12" x2="3" y2="12" stroke="currentColor" stroke-width="2"/>
              <line x1="21" y1="12" x2="23" y2="12" stroke="currentColor" stroke-width="2"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" stroke="currentColor" stroke-width="2"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span id="theme-label" class="text-xs font-medium hidden sm:inline text-gray-300"></span>
          </button>
        </li>
      </ul>
    </div>
  </div>
</nav>


<script>
  const toggleButton = document.getElementById('mobile-menu-toggle');
  const navbarDefault = document.getElementById('navbar-default');

  if (toggleButton && navbarDefault) {
    toggleButton.addEventListener('click', () => {
      navbarDefault.classList.toggle('hidden');
    });
  }

  const btn = document.getElementById('theme-toggle');
  const moon = document.getElementById('icon-moon');
  const sun = document.getElementById('icon-sun');
  const label = document.getElementById('theme-label');

  function syncThemeUI() {
    const dark = document.documentElement.getAttribute('data-theme') === 'dark';
    moon?.classList.toggle('hidden', dark);
    sun?.classList.toggle('hidden', !dark);
    if (label) label.textContent = dark ? 'Açık Mod' : 'Koyu Mod';
  }
  syncThemeUI();
  btn?.addEventListener('click', () => {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    syncThemeUI();
  });
</script>
