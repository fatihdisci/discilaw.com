---
import { getCollection } from 'astro:content';
import BlogCard from './blog/BlogCard.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);
---

<section class="py-24 border-t" style="background: var(--bg-2); border-color: var(--border);">
    <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6" data-aos="fade-up">
            <div>
                <h2 class="text-3xl md:text-5xl font-light mb-4 font-display" style="color: var(--text);">Güncel İçerikler</h2>
                <p class="text-lg font-light" style="color: var(--text-2);">Yapay zeka ve hukuk dünyasından son gelişmeler ve analizler.</p>
            </div>
            <a href="/blog" class="inline-flex items-center gap-2 text-gold-500 font-semibold hover:text-gold-400 transition-colors">
                Tümünü Gör
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
        </div>

        {posts.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {posts.map((post, index) => (
                    <div data-aos="fade-up" data-aos-delay={index * 100}>
                        <BlogCard post={post} />
                    </div>
                ))}
            </div>
        ) : (
            <div class="text-center py-12 rounded-2xl border border-dashed" style="background: var(--bg-3); border-color: var(--border);">
                <p class="text-lg" style="color: var(--text-3);">Henüz yayınlanmış bir yazı bulunmamaktadır.</p>
            </div>
        )}
    </div>
</section>
