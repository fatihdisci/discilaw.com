---
import { getCollection } from 'astro:content';
import BlogCard from './blog/BlogCard.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);
---

<section class="latest-section">
    <div class="container mx-auto px-4">
        <div class="latest-header" data-aos="fade-up">
            <h2 class="latest-title">
                <span class="latest-title-italic">Güncel</span> İçerikler
            </h2>
            <a href="/blog" class="latest-all cursor-pointer">
                Tümünü Gör
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </a>
        </div>

        {posts.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
                {posts.map((post, index) => (
                    <div data-aos="fade-up" data-aos-delay={index * 100}>
                        <BlogCard post={post} />
                    </div>
                ))}
            </div>
        ) : (
            <div class="latest-empty">
                <p>Henüz yayınlanmış bir yazı bulunmamaktadır.</p>
            </div>
        )}
    </div>
</section>

<style>
    .latest-section {
        background: var(--bg-elevated);
        border-top: 1px solid var(--border-soft);
        padding-top: clamp(4rem, 9vw, 6rem);
        padding-bottom: clamp(4rem, 9vw, 6rem);
    }

    .latest-header {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
        align-items: flex-start;
    }
    @media (min-width: 768px) {
        .latest-header {
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-end;
        }
    }

    .latest-title {
        font-family: var(--font-display);
        font-weight: 500;
        font-size: var(--text-h2);
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: var(--ink-strong);
    }
    .latest-title-italic {
        font-style: italic;
        font-weight: 400;
        font-variation-settings: "SOFT" 100, "opsz" 144;
        color: var(--brand-deep);
    }

    .latest-all {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 0.9375rem;
        color: var(--brand-deep);
        border-bottom: 1px solid currentColor;
        padding-bottom: 2px;
        transition: color 200ms ease;
    }
    .latest-all:hover { color: var(--ink-strong); }

    .latest-empty {
        text-align: center;
        padding: 3rem 1.5rem;
        background: var(--bg-base);
        border: 1px dashed var(--border);
        border-radius: var(--radius-lg);
        color: var(--ink-muted);
        font-family: var(--font-sans);
    }
</style>
