---
import Layout from '../../layouts/Layout.astro';
import {
  createSupabaseServerClient,
  PORTAL_ACCESS_COOKIE,
  PORTAL_REFRESH_COOKIE,
} from '../../lib/supabase';

export const prerender = false;

const accessToken = Astro.cookies.get(PORTAL_ACCESS_COOKIE)?.value;

if (!accessToken) {
  return Astro.redirect('/portal/login');
}

const supabase = createSupabaseServerClient(accessToken);

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'logout') {
    await supabase.auth.signOut();
    Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
    Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
    return Astro.redirect('/portal/login');
  }
}

const {
  data: { user },
} = await supabase.auth.getUser(accessToken);

if (!user) {
  Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
  Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
  return Astro.redirect('/portal/login');
}

const { data: profile } = await supabase
  .from('profiles')
  .select('id, role, company_name, username')
  .eq('id', user.id)
  .maybeSingle();

const { data: cases } = await supabase
  .from('cases')
  .select('id, title, description, status, created_at')
  .order('created_at', { ascending: false })
  .limit(8);

const { data: expenses } = await supabase
  .from('expenses')
  .select('id, amount, description, created_at, cases(title)')
  .order('created_at', { ascending: false })
  .limit(8);

const { data: notes } = await supabase
  .from('notes')
  .select('id, content, created_at, cases(title)')
  .order('created_at', { ascending: false })
  .limit(8);

const toplamDosya = cases?.length ?? 0;
const toplamMasraf = expenses?.reduce((sum, item) => sum + Number(item.amount ?? 0), 0) ?? 0;
const toplamNot = notes?.length ?? 0;
const hesapBasligi = profile?.company_name || 'Müvekkil hesabı';
const rolMetni = profile?.role === 'admin' ? 'Yönetici' : 'Müvekkil';
const yonetimLinkiGoster = profile?.role === 'admin';
---

<Layout
  title="Portal Dashboard"
  description="Portal dashboard ekranı."
  showBreadcrumbs={false}
>
  <section class="px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-col gap-6 rounded-[2rem] border border-white/10 bg-slate-900/70 p-8 shadow-2xl shadow-black/20 backdrop-blur xl:flex-row xl:items-end xl:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-gold-400">Portal Dashboard</p>
          <h1 class="mt-3 font-serif text-4xl text-white">{hesapBasligi}</h1>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300 sm:text-base">
            Bu alanda size ait dosya, masraf ve not kayıtlarını görüntüleyebilirsiniz.
          </p>
          <div class="mt-4 flex flex-wrap gap-3 text-sm text-slate-400">
            <span class="rounded-full border border-white/10 px-4 py-2">Rol: {rolMetni}</span>
            <span class="rounded-full border border-white/10 px-4 py-2">Kullanıcı adı: {profile?.username ?? '-'}</span>
          </div>
        </div>

        <div class="flex flex-wrap gap-3">
          {yonetimLinkiGoster && (
            <a
              href="/portal/admin"
              class="rounded-2xl border border-white/10 px-5 py-3 text-sm font-semibold text-slate-200 transition hover:bg-white/5"
            >
              Yönetim paneli
            </a>
          )}

          <form method="POST">
            <input type="hidden" name="action" value="logout" />
            <button
              type="submit"
              class="rounded-2xl border border-gold-500/40 px-5 py-3 text-sm font-semibold text-gold-300 transition hover:border-gold-400 hover:bg-gold-500/10"
            >
              Çıkış Yap
            </button>
          </form>
        </div>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <article class="rounded-[1.75rem] border border-white/10 bg-white/5 p-6">
          <p class="text-sm text-slate-400">Toplam dosya</p>
          <p class="mt-3 text-3xl font-semibold text-white">{toplamDosya}</p>
        </article>
        <article class="rounded-[1.75rem] border border-white/10 bg-white/5 p-6">
          <p class="text-sm text-slate-400">Toplam masraf</p>
          <p class="mt-3 text-3xl font-semibold text-white">{toplamMasraf.toLocaleString('tr-TR')} TL</p>
        </article>
        <article class="rounded-[1.75rem] border border-white/10 bg-white/5 p-6">
          <p class="text-sm text-slate-400">Toplam not</p>
          <p class="mt-3 text-3xl font-semibold text-white">{toplamNot}</p>
        </article>
      </div>

      <div class="mt-8 grid gap-6 xl:grid-cols-3">
        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/60 p-6">
          <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-white">Dosyalar</h2>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-500">Son kayıtlar</span>
          </div>

          {(cases ?? []).length > 0 ? (
            <div class="space-y-4">
              {cases?.map((item) => (
                <article class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="text-sm font-semibold text-white">{item.title}</h3>
                      {item.description && <p class="mt-2 text-sm leading-6 text-slate-400">{item.description}</p>}
                    </div>
                    <span class="rounded-full border border-gold-500/30 px-3 py-1 text-xs text-gold-300">{item.status}</span>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <p class="rounded-2xl border border-dashed border-white/10 px-4 py-6 text-sm leading-6 text-slate-400">
              Henüz dosya kaydı bulunmuyor.
            </p>
          )}
        </section>

        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/60 p-6">
          <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-white">Masraflar</h2>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-500">Son kayıtlar</span>
          </div>

          {(expenses ?? []).length > 0 ? (
            <div class="space-y-4">
              {expenses?.map((item) => (
                <article class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="text-sm font-semibold text-white">{item.cases?.title ?? 'İlgili dosya'}</h3>
                      {item.description && <p class="mt-2 text-sm leading-6 text-slate-400">{item.description}</p>}
                    </div>
                    <span class="text-sm font-semibold text-gold-300">
                      {Number(item.amount ?? 0).toLocaleString('tr-TR')} TL
                    </span>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <p class="rounded-2xl border border-dashed border-white/10 px-4 py-6 text-sm leading-6 text-slate-400">
              Henüz masraf kaydı bulunmuyor.
            </p>
          )}
        </section>

        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/60 p-6">
          <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-white">Notlar</h2>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-500">Son kayıtlar</span>
          </div>

          {(notes ?? []).length > 0 ? (
            <div class="space-y-4">
              {notes?.map((item) => (
                <article class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <h3 class="text-sm font-semibold text-white">{item.cases?.title ?? 'Dosya notu'}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-400">{item.content}</p>
                </article>
              ))}
            </div>
          ) : (
            <p class="rounded-2xl border border-dashed border-white/10 px-4 py-6 text-sm leading-6 text-slate-400">
              Henüz not kaydı bulunmuyor.
            </p>
          )}
        </section>
      </div>
    </div>
  </section>
</Layout>
