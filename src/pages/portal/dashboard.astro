---
import Layout from '../../layouts/Layout.astro';
import {
  createSupabaseServerClient,
  PORTAL_ACCESS_COOKIE,
  PORTAL_REFRESH_COOKIE,
} from '../../lib/supabase';

export const prerender = false;

const accessToken = Astro.cookies.get(PORTAL_ACCESS_COOKIE)?.value;

if (!accessToken) {
  return Astro.redirect('/portal/login');
}

const supabase = createSupabaseServerClient(accessToken);

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'logout') {
    await supabase.auth.signOut();
    Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
    Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
    return Astro.redirect('/portal/login');
  }
}

const {
  data: { user },
} = await supabase.auth.getUser(accessToken);

if (!user) {
  Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
  Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
  return Astro.redirect('/portal/login');
}

const { data: profile } = await supabase
  .from('profiles')
  .select('id, role, company_name, username')
  .eq('id', user.id)
  .maybeSingle();

const { data: cases } = await supabase
  .from('cases')
  .select('id, title, description, status, created_at')
  .order('created_at', { ascending: false })
  .limit(8);

const { data: expenses } = await supabase
  .from('expenses')
  .select('id, amount, description, created_at, cases(title)')
  .order('created_at', { ascending: false })
  .limit(8);

const { data: notes } = await supabase
  .from('notes')
  .select('id, content, created_at, cases(title)')
  .order('created_at', { ascending: false })
  .limit(8);

const toplamDosya = cases?.length ?? 0;
const toplamMasraf = expenses?.reduce((sum, item) => sum + Number(item.amount ?? 0), 0) ?? 0;
const toplamNot = notes?.length ?? 0;
const hesapBasligi = profile?.company_name || 'Müvekkil hesabı';
const rolMetni = profile?.role === 'admin' ? 'Yönetici' : 'Müvekkil';
const yonetimLinkiGoster = profile?.role === 'admin';
---

<Layout
  title="Portal Dashboard"
  description="Portal dashboard ekranı."
  showBreadcrumbs={false}
>
  <section class="portal-dashboard">
    <div class="container mx-auto px-4 max-w-6xl">
      
      <header class="dashboard-header" data-aos="fade-up">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div>
            <span class="post-category mb-4">Portal Dashboard</span>
            <h1 class="portal-h1"><span class="portal-h1-italic">{hesapBasligi.split(' ')[0]}</span> {hesapBasligi.split(' ').slice(1).join(' ')}</h1>
            <p class="portal-lede">Dosya, masraf ve not kayıtlarınıza buradan ulaşabilirsiniz.</p>
          </div>
          <div class="flex flex-wrap gap-3">
            {yonetimLinkiGoster && (
              <a href="/portal/admin" class="portal-outline-link cursor-pointer">Yönetim Paneli</a>
            )}
            <form method="POST">
              <input type="hidden" name="action" value="logout" />
              <button type="submit" class="portal-accent-link cursor-pointer">Çıkış Yap</button>
            </form>
          </div>
        </div>
        
        <div class="dashboard-user-bar mt-8">
          <div class="user-pill">
            <span class="user-pill-label">Rol:</span>
            <span class="user-pill-value">{rolMetni}</span>
          </div>
          <div class="user-pill">
            <span class="user-pill-label">Kullanıcı:</span>
            <span class="user-pill-value">{profile?.username ?? '-'}</span>
          </div>
        </div>
      </header>

      <div class="grid gap-6 md:grid-cols-3 mt-12" data-aos="fade-up">
        <div class="stat-card">
          <p class="stat-label">Toplam Dosya</p>
          <p class="stat-value">{toplamDosya}</p>
        </div>
        <div class="stat-card">
          <p class="stat-label">Toplam Masraf</p>
          <p class="stat-value">{toplamMasraf.toLocaleString('tr-TR')} <span class="text-lg">TL</span></p>
        </div>
        <div class="stat-card">
          <p class="stat-label">Toplam Not</p>
          <p class="stat-value">{toplamNot}</p>
        </div>
      </div>

      <div class="grid gap-10 xl:grid-cols-3 mt-16">
        
        <section class="dashboard-column" data-aos="fade-up">
          <h2 class="column-title"><span class="column-title-italic">Son</span> Dosyalar</h2>
          {(cases ?? []).length > 0 ? (
            <div class="space-y-4">
              {cases?.map((item) => (
                <div class="list-item-card">
                  <div class="flex justify-between items-start mb-2">
                    <h3 class="item-title">{item.title}</h3>
                    <span class="item-badge">{item.status}</span>
                  </div>
                  {item.description && <p class="item-desc">{item.description}</p>}
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-state">Henüz dosya bulunmuyor.</div>
          )}
        </section>

        <section class="dashboard-column" data-aos="fade-up" data-aos-delay="100">
          <h2 class="column-title"><span class="column-title-italic">Son</span> Masraflar</h2>
          {(expenses ?? []).length > 0 ? (
            <div class="space-y-4">
              {expenses?.map((item) => (
                <div class="list-item-card">
                  <div class="flex justify-between items-start mb-1">
                    <h3 class="item-title">{item.cases?.title ?? 'İlgili dosya'}</h3>
                    <span class="item-price">{Number(item.amount ?? 0).toLocaleString('tr-TR')} TL</span>
                  </div>
                  {item.description && <p class="item-desc">{item.description}</p>}
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-state">Henüz masraf bulunmuyor.</div>
          )}
        </section>

        <section class="dashboard-column" data-aos="fade-up" data-aos-delay="200">
          <h2 class="column-title"><span class="column-title-italic">Son</span> Notlar</h2>
          {(notes ?? []).length > 0 ? (
            <div class="space-y-4">
              {notes?.map((item) => (
                <div class="list-item-card">
                  <h3 class="item-title mb-2">{item.cases?.title ?? 'Dosya notu'}</h3>
                  <p class="item-desc">{item.content}</p>
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-state">Henüz not bulunmuyor.</div>
          )}
        </section>

      </div>
    </div>
  </section>
</Layout>

<style>
  .portal-dashboard {
    background: var(--bg-base);
    padding: clamp(3rem, 7vw, 5rem) 0 clamp(4rem, 9vw, 6rem);
    min-height: 100vh;
  }

  .dashboard-header {
    border-bottom: 1px solid var(--border-soft);
    padding-bottom: 2.5rem;
  }

  .portal-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h1);
    letter-spacing: -0.022em;
    color: var(--ink-strong);
    margin: 0;
  }
  .portal-h1-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .portal-lede {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    color: var(--ink-default);
    margin-top: 1rem;
    font-weight: 300;
  }

  .post-category {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    background: var(--brand-soft);
    color: var(--brand-deep);
    border: 1px solid var(--border-soft);
    line-height: 1;
  }

  .dashboard-user-bar {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .user-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
  }
  .user-pill-label { color: var(--ink-muted); font-weight: 400; }
  .user-pill-value { color: var(--ink-strong); font-weight: 600; }

  .portal-outline-link {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-strong);
    transition: all 200ms ease;
  }
  .portal-outline-link:hover {
    background: var(--brand-soft);
    border-color: var(--brand);
    color: var(--brand-deep);
  }

  .portal-accent-link {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    background: var(--brand-deep);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: white;
    transition: all 200ms ease;
  }
  .portal-accent-link:hover {
    background: var(--ink-strong);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  /* STATS */
  .stat-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .stat-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }
  .stat-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 2.5rem;
    color: var(--ink-strong);
    line-height: 1;
  }

  /* COLUMNS */
  .column-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: -0.015em;
    color: var(--ink-strong);
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .column-title-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .list-item-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .list-item-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--brand);
  }

  .item-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.0625rem;
    color: var(--ink-strong);
    margin: 0;
  }
  .item-badge {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    background: var(--brand-soft);
    color: var(--brand-deep);
    border-radius: 4px;
  }
  .item-price {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--brand-deep);
  }
  .item-desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ink-muted);
    margin-top: 0.25rem;
  }

  .empty-state {
    padding: 2.5rem;
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
    text-align: center;
    color: var(--ink-faint);
    font-size: 0.875rem;
    font-family: var(--font-sans);
  }
</style>
