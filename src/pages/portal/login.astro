---
import Layout from '../../layouts/Layout.astro';
import {
  createSupabaseAdminClient,
  createSupabaseServerClient,
  PORTAL_ACCESS_COOKIE,
  PORTAL_REFRESH_COOKIE,
} from '../../lib/supabase';

export const prerender = false;

let hataMesaji = '';
let sistemMesaji = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const username = formData.get('username');
    const password = formData.get('password');

    if (typeof username !== 'string' || typeof password !== 'string' || !username || !password) {
      hataMesaji = 'Lütfen kullanıcı adı ve şifre alanlarını doldurun.';
    } else {
      const normalizedUsername = username.trim().toLowerCase();
      const emailDomain = import.meta.env.PORTAL_LOGIN_EMAIL_DOMAIN || 'portal.local';
      const generatedEmail = `${normalizedUsername}@${emailDomain}`;
      const supabase = createSupabaseServerClient();

      const { data: directLoginData, error: directLoginError } = await supabase.auth.signInWithPassword({
        email: generatedEmail,
        password,
      });

      if (!directLoginError && directLoginData.session && directLoginData.user) {
        const authSupabase = createSupabaseServerClient(directLoginData.session.access_token);
        const { data: ownProfile } = await authSupabase
          .from('profiles')
          .select('role')
          .eq('id', directLoginData.user.id)
          .maybeSingle();

        Astro.cookies.set(PORTAL_ACCESS_COOKIE, directLoginData.session.access_token, {
          httpOnly: true,
          path: '/',
          sameSite: 'lax',
          secure: Astro.url.protocol === 'https:',
          maxAge: directLoginData.session.expires_in,
        });

        Astro.cookies.set(PORTAL_REFRESH_COOKIE, directLoginData.session.refresh_token, {
          httpOnly: true,
          path: '/',
          sameSite: 'lax',
          secure: Astro.url.protocol === 'https:',
          maxAge: 60 * 60 * 24 * 30,
        });

        return Astro.redirect(ownProfile?.role === 'admin' ? '/portal/admin' : '/portal/dashboard');
      }

      const adminSupabase = createSupabaseAdminClient();
      const { data: profile, error: profileError } = await adminSupabase
        .from('profiles')
        .select('id, role, username')
        .eq('username', normalizedUsername)
        .maybeSingle();

      if (profileError || !profile) {
        hataMesaji = 'Kullanıcı adı veya şifre hatalı.';
      } else {
        const { data: authUserData, error: authUserError } = await adminSupabase.auth.admin.getUserById(profile.id);
        const email = authUserData?.user?.email;

        if (authUserError || !email) {
          hataMesaji = 'Kullanıcı hesabı doğrulanamadı.';
        } else {
          const { data, error } = await supabase.auth.signInWithPassword({
            email,
            password,
          });

          if (error || !data.session) {
            hataMesaji = 'Kullanıcı adı veya şifre hatalı.';
          } else {
            Astro.cookies.set(PORTAL_ACCESS_COOKIE, data.session.access_token, {
              httpOnly: true,
              path: '/',
              sameSite: 'lax',
              secure: Astro.url.protocol === 'https:',
              maxAge: data.session.expires_in,
            });

            Astro.cookies.set(PORTAL_REFRESH_COOKIE, data.session.refresh_token, {
              httpOnly: true,
              path: '/',
              sameSite: 'lax',
              secure: Astro.url.protocol === 'https:',
              maxAge: 60 * 60 * 24 * 30,
            });

            return Astro.redirect(profile.role === 'admin' ? '/portal/admin' : '/portal/dashboard');
          }
        }
      }
    }
  } catch {
    hataMesaji = 'Portal girişi geçici olarak kullanılamıyor. Lütfen yönetici ile iletişime geçin.';
  }
}

if (!import.meta.env.PUBLIC_SUPABASE_URL || !import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  sistemMesaji = 'Portal geçici olarak kullanılamıyor. Lütfen daha sonra tekrar deneyin.';
}
---

<Layout
  title="Portal Giriş"
  description="Portal giriş sayfası."
  showBreadcrumbs={false}
>
  <section class="relative isolate overflow-hidden px-6 py-20 sm:px-8 lg:px-12">
    <div class="absolute inset-0 bg-[linear-gradient(180deg,_rgba(15,23,42,0.96),_rgba(2,6,23,1))]"></div>
    <div class="relative mx-auto max-w-md">
      <div class="rounded-[2rem] border border-white/10 bg-slate-900/85 p-8 shadow-2xl shadow-black/30 backdrop-blur">
        <div class="mb-8">
          <h1 class="font-serif text-3xl text-white">Portal Girişi</h1>
          <p class="mt-3 text-sm leading-6 text-slate-400">
            Kullanıcı adınız ve şifreniz ile giriş yapın.
          </p>
        </div>

        {hataMesaji && (
          <div class="mb-6 rounded-2xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-200">
            {hataMesaji}
          </div>
        )}
        {sistemMesaji && (
          <div class="mb-6 rounded-2xl border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-200">
            {sistemMesaji}
          </div>
        )}

        <form method="POST" class="space-y-5">
          <div>
            <label for="username" class="mb-2 block text-sm font-medium text-slate-200">Kullanıcı adı</label>
            <input
              id="username"
              name="username"
              type="text"
              autocomplete="username"
              required
              class="w-full rounded-2xl border border-white/10 bg-slate-950/80 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/30"
              placeholder="musteri_kullanici_adi"
            />
          </div>

          <div>
            <label for="password" class="mb-2 block text-sm font-medium text-slate-200">Şifre</label>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
              class="w-full rounded-2xl border border-white/10 bg-slate-950/80 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/30"
              placeholder="Şifrenizi girin"
            />
          </div>

          <button
            type="submit"
            class="w-full rounded-2xl bg-gold-500 px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-gold-400 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:ring-offset-2 focus:ring-offset-slate-900"
          >
            Giriş Yap
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
