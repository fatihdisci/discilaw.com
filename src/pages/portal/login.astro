---
import Layout from '../../layouts/Layout.astro';
import {
  createSupabaseAdminClient,
  createSupabaseServerClient,
  PORTAL_ACCESS_COOKIE,
  PORTAL_REFRESH_COOKIE,
} from '../../lib/supabase';

export const prerender = false;

let hataMesaji = '';
let sistemMesaji = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const username = formData.get('username');
    const password = formData.get('password');

    if (typeof username !== 'string' || typeof password !== 'string' || !username || !password) {
      hataMesaji = 'Lütfen kullanıcı adı ve şifre alanlarını doldurun.';
    } else {
      const normalizedUsername = username.trim().toLowerCase();
      const emailDomain = import.meta.env.PORTAL_LOGIN_EMAIL_DOMAIN || 'portal.local';
      const generatedEmail = `${normalizedUsername}@${emailDomain}`;
      const supabase = createSupabaseServerClient();

      const { data: directLoginData, error: directLoginError } = await supabase.auth.signInWithPassword({
        email: generatedEmail,
        password,
      });

      if (!directLoginError && directLoginData.session && directLoginData.user) {
        const authSupabase = createSupabaseServerClient(directLoginData.session.access_token);
        const { data: ownProfile } = await authSupabase
          .from('profiles')
          .select('role')
          .eq('id', directLoginData.user.id)
          .maybeSingle();

        Astro.cookies.set(PORTAL_ACCESS_COOKIE, directLoginData.session.access_token, {
          httpOnly: true,
          path: '/',
          sameSite: 'lax',
          secure: Astro.url.protocol === 'https:',
          maxAge: directLoginData.session.expires_in,
        });

        Astro.cookies.set(PORTAL_REFRESH_COOKIE, directLoginData.session.refresh_token, {
          httpOnly: true,
          path: '/',
          sameSite: 'lax',
          secure: Astro.url.protocol === 'https:',
          maxAge: 60 * 60 * 24 * 30,
        });

        return Astro.redirect(ownProfile?.role === 'admin' ? '/portal/admin' : '/portal/dashboard');
      }

      const adminSupabase = createSupabaseAdminClient();
      const { data: profile, error: profileError } = await adminSupabase
        .from('profiles')
        .select('id, role, username')
        .eq('username', normalizedUsername)
        .maybeSingle();

      if (profileError || !profile) {
        hataMesaji = 'Kullanıcı adı veya şifre hatalı.';
      } else {
        const { data: authUserData, error: authUserError } = await adminSupabase.auth.admin.getUserById(profile.id);
        const email = authUserData?.user?.email;

        if (authUserError || !email) {
          hataMesaji = 'Kullanıcı hesabı doğrulanamadı.';
        } else {
          const { data, error } = await supabase.auth.signInWithPassword({
            email,
            password,
          });

          if (error || !data.session) {
            hataMesaji = 'Kullanıcı adı veya şifre hatalı.';
          } else {
            Astro.cookies.set(PORTAL_ACCESS_COOKIE, data.session.access_token, {
              httpOnly: true,
              path: '/',
              sameSite: 'lax',
              secure: Astro.url.protocol === 'https:',
              maxAge: data.session.expires_in,
            });

            Astro.cookies.set(PORTAL_REFRESH_COOKIE, data.session.refresh_token, {
              httpOnly: true,
              path: '/',
              sameSite: 'lax',
              secure: Astro.url.protocol === 'https:',
              maxAge: 60 * 60 * 24 * 30,
            });

            return Astro.redirect(profile.role === 'admin' ? '/portal/admin' : '/portal/dashboard');
          }
        }
      }
    }
  } catch {
    hataMesaji = 'Portal girişi geçici olarak kullanılamıyor. Lütfen yönetici ile iletişime geçin.';
  }
}

if (!import.meta.env.PUBLIC_SUPABASE_URL || !import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  sistemMesaji = 'Portal geçici olarak kullanılamıyor. Lütfen daha sonra tekrar deneyin.';
}
---

<Layout
  title="Portal Giriş"
  description="Portal giriş sayfası."
  showBreadcrumbs={false}
>
  <section class="portal-login-section">
    <div class="container mx-auto px-4 flex flex-col items-center">
      
      <header class="text-center mb-10" data-aos="fade-up">
        <h1 class="portal-h1">Portal <span class="portal-h1-italic">Girişi</span></h1>
        <p class="portal-lede">Hoş Geldiniz. Lütfen bilgilerinizi girin.</p>
      </header>

      <div class="portal-card-wrap" data-aos="fade-up" data-aos-delay="100">
        <div class="portal-card">
          {hataMesaji && (
            <div class="portal-alert danger">
              {hataMesaji}
            </div>
          )}
          {sistemMesaji && (
            <div class="portal-alert warning">
              {sistemMesaji}
            </div>
          )}

          <form method="POST" class="portal-form">
            <div class="form-group">
              <label for="username" class="form-label">Kullanıcı Adı</label>
              <input
                id="username"
                name="username"
                type="text"
                autocomplete="username"
                required
                class="form-input"
                placeholder="kullanici_adi"
              />
            </div>

            <div class="form-group">
              <label for="password" class="form-label">Şifre</label>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
                class="form-input"
                placeholder="••••••••"
              />
            </div>

            <button type="submit" class="portal-submit-btn cursor-pointer">
              Giriş Yap
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </button>
          </form>
        </div>
        
        <div class="text-center mt-8">
          <a href="/" class="portal-back-link">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
            </svg>
            Siteye Dön
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .portal-login-section {
    background: var(--bg-base);
    padding: clamp(4rem, 10vw, 8rem) 0;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .portal-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h1);
    letter-spacing: -0.022em;
    color: var(--ink-strong);
    margin: 0;
  }
  .portal-h1-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .portal-lede {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--ink-muted);
    margin-top: 1rem;
    font-weight: 300;
  }

  .portal-card-wrap {
    width: 100%;
    max-width: 420px;
  }

  .portal-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 5vw, 2.75rem);
    box-shadow: var(--shadow-lg);
  }

  .portal-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .form-input {
    width: 100%;
    height: 52px;
    padding: 0 16px;
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--ink-strong);
    transition: border-color 200ms ease, box-shadow 200ms ease;
    outline: none;
  }
  .form-input:focus {
    border-color: var(--brand);
    box-shadow: 0 0 0 4px var(--brand-soft);
  }

  .portal-submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 16px;
    background: var(--brand-deep);
    color: white;
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: transform 200ms ease, background 200ms ease, box-shadow 200ms ease;
    margin-top: 0.5rem;
  }
  .portal-submit-btn:hover {
    background: var(--ink-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }
  .portal-submit-btn svg {
    transition: transform 220ms ease;
  }
  .portal-submit-btn:hover svg {
    transform: translateX(4px);
  }

  .portal-alert {
    padding: 1rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    text-align: center;
    font-weight: 500;
  }
  .portal-alert.danger {
    background: rgba(168, 68, 42, 0.08);
    color: var(--danger);
    border: 1px solid rgba(168, 68, 42, 0.15);
  }
  .portal-alert.warning {
    background: rgba(200, 98, 58, 0.08);
    color: var(--accent);
    border: 1px solid rgba(200, 98, 58, 0.15);
  }

  .portal-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--ink-muted);
    transition: color 200ms ease;
  }
  .portal-back-link:hover {
    color: var(--brand-deep);
  }
  .portal-back-link svg {
    transition: transform 220ms ease;
  }
  .portal-back-link:hover svg {
    transform: translateX(-4px);
  }
</style>
