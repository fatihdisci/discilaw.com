---
import Layout from '../../layouts/Layout.astro';
import {
  createSupabaseServerClient,
  PORTAL_ACCESS_COOKIE,
  PORTAL_REFRESH_COOKIE,
} from '../../lib/supabase';

export const prerender = false;

const accessToken = Astro.cookies.get(PORTAL_ACCESS_COOKIE)?.value;

if (!accessToken) {
  return Astro.redirect('/portal/login');
}

const supabase = createSupabaseServerClient(accessToken);

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'logout') {
    await supabase.auth.signOut();
    Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
    Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
    return Astro.redirect('/portal/login');
  }
}

const {
  data: { user },
} = await supabase.auth.getUser(accessToken);

if (!user) {
  Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
  Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
  return Astro.redirect('/portal/login');
}

const { data: currentProfile } = await supabase
  .from('profiles')
  .select('id, role')
  .eq('id', user.id)
  .maybeSingle();

if (!currentProfile || currentProfile.role !== 'admin') {
  return Astro.redirect('/portal/dashboard');
}

const { data: clients } = await supabase
  .from('profiles')
  .select('id, username, company_name, created_at, cases(id)')
  .eq('role', 'client')
  .order('company_name', { ascending: true });

const toplamMuvekkil = clients?.length ?? 0;
const toplamDosya = clients?.reduce((sum, item) => sum + (item.cases?.length ?? 0), 0) ?? 0;
---

<Layout
  title="Portal Yönetimi"
  description="Portal yönetim paneli."
  showBreadcrumbs={false}
>
  <section class="portal-admin">
    <div class="container mx-auto px-4 max-w-7xl">
      
      <header class="dashboard-header" data-aos="fade-up">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div>
            <span class="post-category mb-4">Yönetim Paneli</span>
            <h1 class="portal-h1"><span class="portal-h1-italic">Müvekkil</span> Yönetimi</h1>
            <p class="portal-lede">Müvekkilleri buradan yönetin, kayıtlarını düzenleyin.</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/portal/admin/muvekkiller/yeni" class="portal-accent-link cursor-pointer">Yeni Müvekkil Ekle</a>
            <a href="/portal/dashboard" class="portal-outline-link cursor-pointer">Dashboard</a>
            <form method="POST">
              <input type="hidden" name="action" value="logout" />
              <button type="submit" class="portal-outline-link cursor-pointer hover:!text-[var(--danger)] hover:!border-[var(--danger)]">Çıkış</button>
            </form>
          </div>
        </div>
        <p class="mt-6 text-[10px] font-bold uppercase tracking-widest text-[var(--ink-faint)]">Giriş yapan: {user.email}</p>
      </header>

      <div class="grid gap-6 md:grid-cols-3 mt-12" data-aos="fade-up">
        <div class="stat-card">
          <p class="stat-label">Toplam Müvekkil</p>
          <p class="stat-value">{toplamMuvekkil}</p>
        </div>
        <div class="stat-card">
          <p class="stat-label">Toplam Dosya</p>
          <p class="stat-value">{toplamDosya}</p>
        </div>
        <div class="stat-card">
          <p class="stat-label">Aktif Rol</p>
          <p class="stat-value text-2xl !font-sans uppercase tracking-widest text-[var(--brand-deep)]">Yönetici</p>
        </div>
      </div>

      <section class="mt-16" data-aos="fade-up">
        <h2 class="column-title"><span class="column-title-italic">Müvekkil</span> Listesi</h2>
        
        {(clients ?? []).length > 0 ? (
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3 mt-8">
            {clients?.map((item) => (
              <a href={`/portal/admin/muvekkiller/${item.id}`} class="client-card group cursor-pointer">
                <div class="flex justify-between items-start mb-4">
                  <h3 class="client-name">{item.company_name ?? 'Muvekkil'}</h3>
                  <svg class="w-5 h-5 text-[var(--ink-faint)] group-hover:text-[var(--brand)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
                <div class="space-y-2">
                  <div class="flex justify-between text-xs font-medium uppercase tracking-wider">
                    <span class="text-[var(--ink-muted)]">Kullanıcı:</span>
                    <span class="text-[var(--ink-strong)]">{item.username ?? '-'}</span>
                  </div>
                  <div class="flex justify-between text-xs font-medium uppercase tracking-wider">
                    <span class="text-[var(--ink-muted)]">Dosya Sayısı:</span>
                    <span class="text-[var(--brand-deep)] font-bold">{item.cases?.length ?? 0}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="empty-state mt-8">Henüz müvekkil kaydı bulunmuyor.</div>
        )}
      </section>

    </div>
  </section>
</Layout>

<style>
  .portal-admin {
    background: var(--bg-base);
    padding: clamp(3rem, 7vw, 5rem) 0 clamp(4rem, 9vw, 6rem);
    min-height: 100vh;
  }

  .dashboard-header {
    border-bottom: 1px solid var(--border-soft);
    padding-bottom: 2.5rem;
  }

  .portal-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h1);
    letter-spacing: -0.022em;
    color: var(--ink-strong);
    margin: 0;
  }
  .portal-h1-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .portal-lede {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    color: var(--ink-default);
    margin-top: 1rem;
    font-weight: 300;
  }

  .post-category {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    background: var(--brand-soft);
    color: var(--brand-deep);
    border: 1px solid var(--border-soft);
    line-height: 1;
  }

  .portal-outline-link {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-strong);
    transition: all 200ms ease;
  }
  .portal-outline-link:hover {
    background: var(--brand-soft);
    border-color: var(--brand);
    color: var(--brand-deep);
  }

  .portal-accent-link {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    background: var(--brand-deep);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: white;
    transition: all 200ms ease;
  }
  .portal-accent-link:hover {
    background: var(--ink-strong);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  /* STATS */
  .stat-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .stat-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }
  .stat-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 2.5rem;
    color: var(--ink-strong);
    line-height: 1;
  }

  .column-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.75rem;
    letter-spacing: -0.015em;
    color: var(--ink-strong);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .column-title-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .client-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: all 280ms ease;
  }
  .client-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--brand);
  }
  .client-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.125rem;
    color: var(--ink-strong);
  }

  .empty-state {
    padding: 3rem;
    border: 1px dashed var(--border);
    border-radius: var(--radius-lg);
    text-align: center;
    color: var(--ink-faint);
    font-family: var(--font-sans);
  }
</style>
