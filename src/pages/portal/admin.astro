---
import Layout from '../../layouts/Layout.astro';
import {
  createSupabaseServerClient,
  PORTAL_ACCESS_COOKIE,
  PORTAL_REFRESH_COOKIE,
} from '../../lib/supabase';

export const prerender = false;

const accessToken = Astro.cookies.get(PORTAL_ACCESS_COOKIE)?.value;

if (!accessToken) {
  return Astro.redirect('/portal/login');
}

const supabase = createSupabaseServerClient(accessToken);

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'logout') {
    await supabase.auth.signOut();
    Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
    Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
    return Astro.redirect('/portal/login');
  }
}

const {
  data: { user },
} = await supabase.auth.getUser(accessToken);

if (!user) {
  Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
  Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
  return Astro.redirect('/portal/login');
}

const { data: currentProfile } = await supabase
  .from('profiles')
  .select('id, role')
  .eq('id', user.id)
  .maybeSingle();

if (!currentProfile || currentProfile.role !== 'admin') {
  return Astro.redirect('/portal/dashboard');
}

const { data: clients } = await supabase
  .from('profiles')
  .select('id, username, company_name, created_at, cases(id)')
  .eq('role', 'client')
  .order('company_name', { ascending: true });

const toplamMuvekkil = clients?.length ?? 0;
const toplamDosya = clients?.reduce((sum, item) => sum + (item.cases?.length ?? 0), 0) ?? 0;
---

<Layout
  title="Portal Yonetimi"
  description="Portal yonetim paneli."
  showBreadcrumbs={false}
>
  <section class="px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-7xl space-y-8">
      <div class="flex flex-col gap-4 rounded-[2rem] border border-white/10 bg-slate-900/70 p-8 shadow-2xl shadow-black/20 backdrop-blur lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-gold-400">Yonetim Paneli</p>
          <h1 class="mt-3 font-serif text-4xl text-white">Muvekkil yonetimi</h1>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300 sm:text-base">
            Muvekkilleri buradan yonetin. Her muvekkil kartina tiklayarak o kisiye ait dosya, masraf ve not kayitlarini
            ayri bir ekranda yonetebilirsiniz.
          </p>
          <p class="mt-2 text-sm text-slate-400">Giris yapan hesap: {user.email}</p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a
            href="/portal/admin/muvekkiller/yeni"
            class="rounded-2xl bg-gold-500 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-gold-400"
          >
            Yeni Muvekkil Ekle
          </a>
          <a
            href="/portal/dashboard"
            class="rounded-2xl border border-white/10 px-5 py-3 text-sm font-semibold text-slate-200 transition hover:bg-white/5"
          >
            Dashboard
          </a>
          <form method="POST">
            <input type="hidden" name="action" value="logout" />
            <button
              type="submit"
              class="rounded-2xl border border-gold-500/40 px-5 py-3 text-sm font-semibold text-gold-300 transition hover:border-gold-400 hover:bg-gold-500/10"
            >
              Cikis Yap
            </button>
          </form>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <article class="rounded-[1.75rem] border border-white/10 bg-white/5 p-6">
          <p class="text-sm text-slate-400">Toplam muvekkil</p>
          <p class="mt-3 text-3xl font-semibold text-white">{toplamMuvekkil}</p>
        </article>
        <article class="rounded-[1.75rem] border border-white/10 bg-white/5 p-6">
          <p class="text-sm text-slate-400">Toplam dosya</p>
          <p class="mt-3 text-3xl font-semibold text-white">{toplamDosya}</p>
        </article>
        <article class="rounded-[1.75rem] border border-white/10 bg-white/5 p-6">
          <p class="text-sm text-slate-400">Aktif rol</p>
          <p class="mt-3 text-3xl font-semibold text-white">Yonetici</p>
        </article>
      </div>

      <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/60 p-6">
        <div class="mb-5 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-white">Muvekkil listesi</h2>
          <span class="text-xs uppercase tracking-[0.2em] text-slate-500">Detay icin tiklayin</span>
        </div>

        {(clients ?? []).length > 0 ? (
          <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {clients?.map((item) => (
              <a
                href={`/portal/admin/muvekkiller/${item.id}`}
                class="rounded-2xl border border-white/10 bg-white/5 p-5 transition hover:border-gold-500/40 hover:bg-white/10"
              >
                <p class="text-base font-semibold text-white">{item.company_name ?? 'Muvekkil'}</p>
                <p class="mt-2 text-sm text-slate-400">Kullanici adi: {item.username ?? '-'}</p>
                <p class="mt-2 text-sm text-slate-400">Dosya sayisi: {item.cases?.length ?? 0}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="rounded-2xl border border-dashed border-white/10 px-4 py-6 text-sm text-slate-400">
            Henuz muvekkil kaydi bulunmuyor.
          </p>
        )}
      </section>
    </div>
  </section>
</Layout>
