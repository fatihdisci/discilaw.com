---
import Layout from '../../../../layouts/Layout.astro';
import {
  createSupabaseAdminClient,
  createSupabaseServerClient,
  PORTAL_ACCESS_COOKIE,
  PORTAL_REFRESH_COOKIE,
} from '../../../../lib/supabase';

export const prerender = false;

type FormState = {
  type: 'success' | 'error';
  message: string;
} | null;

const accessToken = Astro.cookies.get(PORTAL_ACCESS_COOKIE)?.value;

if (!accessToken) {
  return Astro.redirect('/portal/login');
}

const supabase = createSupabaseServerClient(accessToken);

const {
  data: { user },
} = await supabase.auth.getUser(accessToken);

if (!user) {
  Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
  Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
  return Astro.redirect('/portal/login');
}

const { data: currentProfile } = await supabase
  .from('profiles')
  .select('id, role')
  .eq('id', user.id)
  .maybeSingle();

if (!currentProfile || currentProfile.role !== 'admin') {
  return Astro.redirect('/portal/dashboard');
}

let formState: FormState = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'logout') {
    await supabase.auth.signOut();
    Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
    Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
    return Astro.redirect('/portal/login');
  }

  if (action === 'create-client') {
    const companyName = formData.get('company_name');
    const username = formData.get('username');
    const password = formData.get('password');

    if (
      typeof companyName !== 'string' ||
      typeof username !== 'string' ||
      typeof password !== 'string' ||
      !companyName.trim() ||
      !username.trim() ||
      !password.trim()
    ) {
      formState = { type: 'error', message: 'Tüm alanları doldurun.' };
    } else {
      const normalizedUsername = username.trim().toLowerCase();
      const usernameRegex = /^[a-z0-9._-]{3,30}$/;

      if (!usernameRegex.test(normalizedUsername)) {
        formState = {
          type: 'error',
          message: 'Kullanıcı adı 3-30 karakter olmalı ve sadece a-z, 0-9, nokta, tire, alt çizgi içermelidir.',
        };
      } else if (password.length < 8) {
        formState = { type: 'error', message: 'Şifre en az 8 karakter olmalıdır.' };
      } else {
        const adminSupabase = createSupabaseAdminClient();

        const { data: existingProfile } = await adminSupabase
          .from('profiles')
          .select('id')
          .eq('username', normalizedUsername)
          .maybeSingle();

        if (existingProfile) {
          formState = { type: 'error', message: 'Bu kullanıcı adı zaten kullanılıyor.' };
        } else {
          const emailDomain = import.meta.env.PORTAL_LOGIN_EMAIL_DOMAIN || 'portal.local';
          const email = `${normalizedUsername}@${emailDomain}`;

          const { data: authData, error: authError } = await adminSupabase.auth.admin.createUser({
            email,
            password,
            email_confirm: true,
            user_metadata: {
              username: normalizedUsername,
              company_name: companyName.trim(),
            },
          });

          if (authError || !authData.user) {
            formState = {
              type: 'error',
              message: 'Kullanıcı hesabı oluşturulamadı. Kullanıcı adı daha önce kullanılmış olabilir.',
            };
          } else {
            const { error: profileError } = await adminSupabase.from('profiles').insert({
              id: authData.user.id,
              role: 'client',
              company_name: companyName.trim(),
              username: normalizedUsername,
            });

            if (profileError) {
              await adminSupabase.auth.admin.deleteUser(authData.user.id);
              formState = { type: 'error', message: 'Müvekkil kaydı oluşturulamadı.' };
            } else {
              return Astro.redirect(`/portal/admin/muvekkiller/${authData.user.id}?created=1`);
            }
          }
        }
      }
    }
  }
}
---

<Layout
  title="Yeni Müvekkil"
  description="Portal yeni müvekkil kaydı."
  showBreadcrumbs={false}
>
  <section class="portal-admin-yeni">
    <div class="container mx-auto px-4 max-w-3xl">
      
      <header class="dashboard-header mb-12" data-aos="fade-up">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div>
            <span class="post-category mb-4">Müvekkil Yönetimi</span>
            <h1 class="portal-h1"><span class="portal-h1-italic">Yeni</span> Müvekkil Ekle</h1>
            <p class="portal-lede">Sisteme yeni bir müvekkil ve giriş hesabı tanımlayın.</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/portal/admin" class="portal-outline-link cursor-pointer">Panel'e Dön</a>
          </div>
        </div>
      </header>

      {formState && (
        <div class:list={['portal-alert mb-8', formState.type === 'success' ? 'success' : 'danger']} data-aos="fade-up">
          {formState.message}
        </div>
      )}

      <div class="portal-card" data-aos="fade-up" data-aos-delay="100">
        <div class="portal-info-box mb-8">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p>Bu form ile müvekkilin sisteme giriş hesabı otomatik oluşturulur. Supabase Auth tarafında manuel işlem yapmanıza gerek kalmaz.</p>
        </div>

        <form method="POST" class="portal-form">
          <input type="hidden" name="action" value="create-client" />

          <div class="form-group">
            <label for="company_name" class="form-label">Müvekkil Adı / Ünvanı</label>
            <input
              id="company_name"
              name="company_name"
              required
              class="form-input"
              placeholder="Örn: Örnek Şirket A.Ş."
            />
          </div>

          <div class="form-group">
            <label for="username" class="form-label">Kullanıcı Adı</label>
            <input
              id="username"
              name="username"
              required
              class="form-input"
              placeholder="ornek_sirket"
            />
            <p class="text-[10px] text-[var(--ink-faint)] mt-1 uppercase tracking-wider">Sadece küçük harf, rakam ve nokta/tire içerebilir.</p>
          </div>

          <div class="form-group">
            <label for="password" class="form-label">Giriş Şifresi</label>
            <input
              id="password"
              name="password"
              type="password"
              minlength="8"
              required
              class="form-input"
              placeholder="En az 8 karakter"
            />
          </div>

          <button type="submit" class="portal-submit-btn cursor-pointer mt-4">
            Müvekkili Oluştur
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </button>
        </form>
      </div>

    </div>
  </section>
</Layout>

<style>
  .portal-admin-yeni {
    background: var(--bg-base);
    padding: clamp(3rem, 7vw, 5rem) 0 clamp(4rem, 9vw, 6rem);
    min-height: 100vh;
  }

  .dashboard-header {
    border-bottom: 1px solid var(--border-soft);
    padding-bottom: 2.5rem;
  }

  .portal-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h1);
    letter-spacing: -0.022em;
    color: var(--ink-strong);
    margin: 0;
  }
  .portal-h1-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .portal-lede {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    color: var(--ink-default);
    margin-top: 1rem;
    font-weight: 300;
  }

  .post-category {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    background: var(--brand-soft);
    color: var(--brand-deep);
    border: 1px solid var(--border-soft);
    line-height: 1;
  }

  .portal-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 5vw, 3rem);
    box-shadow: var(--shadow-lg);
  }

  .portal-info-box {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--brand-soft);
    border-radius: var(--radius-md);
    color: var(--brand-deep);
    font-size: 0.875rem;
    line-height: 1.5;
    font-family: var(--font-sans);
    font-weight: 500;
  }

  .portal-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .form-input {
    width: 100%;
    height: 52px;
    padding: 0 16px;
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--ink-strong);
    outline: none;
    transition: all 200ms ease;
  }
  .form-input:focus { border-color: var(--brand); box-shadow: 0 0 0 4px var(--brand-soft); }

  .portal-submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 16px;
    background: var(--brand-deep);
    color: white;
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: all 200ms ease;
  }
  .portal-submit-btn:hover { background: var(--ink-strong); transform: translateY(-2px); box-shadow: var(--shadow-glow); }
  .portal-submit-btn svg { transition: transform 220ms ease; }
  .portal-submit-btn:hover svg { transform: translateX(4px); }

  .portal-outline-link {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-strong);
    transition: all 200ms ease;
  }
  .portal-outline-link:hover { background: var(--brand-soft); border-color: var(--brand); color: var(--brand-deep); }

  .portal-alert { padding: 1rem; border-radius: var(--radius-md); font-size: 0.875rem; text-align: center; font-weight: 500; }
  .portal-alert.success { background: rgba(107, 142, 78, 0.08); color: var(--success); border: 1px solid rgba(107, 142, 78, 0.15); }
  .portal-alert.danger { background: rgba(168, 68, 42, 0.08); color: var(--danger); border: 1px solid rgba(168, 68, 42, 0.15); }
</style>
