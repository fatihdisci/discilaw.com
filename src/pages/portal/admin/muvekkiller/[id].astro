---
import Layout from '../../../../layouts/Layout.astro';
import {
  createSupabaseServerClient,
  PORTAL_ACCESS_COOKIE,
  PORTAL_REFRESH_COOKIE,
} from '../../../../lib/supabase';

export const prerender = false;

type FormState = {
  type: 'success' | 'error';
  message: string;
} | null;

const clientId = Astro.params.id;

if (!clientId) {
  return Astro.redirect('/portal/admin');
}

const accessToken = Astro.cookies.get(PORTAL_ACCESS_COOKIE)?.value;

if (!accessToken) {
  return Astro.redirect('/portal/login');
}

const supabase = createSupabaseServerClient(accessToken);

const {
  data: { user },
} = await supabase.auth.getUser(accessToken);

if (!user) {
  Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
  Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
  return Astro.redirect('/portal/login');
}

const { data: currentProfile } = await supabase
  .from('profiles')
  .select('id, role')
  .eq('id', user.id)
  .maybeSingle();

if (!currentProfile || currentProfile.role !== 'admin') {
  return Astro.redirect('/portal/dashboard');
}

let formState: FormState = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'logout') {
    await supabase.auth.signOut();
    Astro.cookies.delete(PORTAL_ACCESS_COOKIE, { path: '/' });
    Astro.cookies.delete(PORTAL_REFRESH_COOKIE, { path: '/' });
    return Astro.redirect('/portal/login');
  }

  if (action === 'create-case') {
    const title = formData.get('title');
    const description = formData.get('description');
    const status = formData.get('status');

    if (typeof title !== 'string' || typeof status !== 'string' || !title.trim() || !status.trim()) {
      formState = { type: 'error', message: 'Dosya kaydı için zorunlu alanları doldurun.' };
    } else {
      const { error } = await supabase.from('cases').insert({
        client_id: clientId,
        title: title.trim(),
        description: typeof description === 'string' && description.trim() ? description.trim() : null,
        status: status.trim(),
      });

      formState = error
        ? { type: 'error', message: 'Dosya kaydı oluşturulamadı.' }
        : { type: 'success', message: 'Dosya kaydı oluşturuldu.' };
    }
  }

  if (action === 'create-expense') {
    const caseId = formData.get('case_id');
    const amount = formData.get('amount');
    const description = formData.get('description');
    const receiptUrl = formData.get('receipt_url');

    if (
      typeof caseId !== 'string' ||
      typeof amount !== 'string' ||
      !caseId ||
      !amount ||
      Number.isNaN(Number(amount))
    ) {
      formState = { type: 'error', message: 'Masraf kaydı için geçerli alanlar girin.' };
    } else {
      const { error } = await supabase.from('expenses').insert({
        case_id: caseId,
        amount: Number(amount),
        description: typeof description === 'string' && description.trim() ? description.trim() : null,
        receipt_url: typeof receiptUrl === 'string' && receiptUrl.trim() ? receiptUrl.trim() : null,
      });

      formState = error
        ? { type: 'error', message: 'Masraf kaydı oluşturulamadı.' }
        : { type: 'success', message: 'Masraf kaydı oluşturuldu.' };
    }
  }

  if (action === 'create-note') {
    const caseId = formData.get('case_id');
    const content = formData.get('content');

    if (typeof caseId !== 'string' || typeof content !== 'string' || !caseId || !content.trim()) {
      formState = { type: 'error', message: 'Not eklemek için tüm alanları doldurun.' };
    } else {
      const { error } = await supabase.from('notes').insert({
        case_id: caseId,
        content: content.trim(),
      });

      formState = error
        ? { type: 'error', message: 'Not kaydı oluşturulamadı.' }
        : { type: 'success', message: 'Not kaydı oluşturuldu.' };
    }
  }
}

const { data: clientProfile } = await supabase
  .from('profiles')
  .select('id, username, company_name, role, created_at')
  .eq('id', clientId)
  .maybeSingle();

if (!clientProfile || clientProfile.role !== 'client') {
  return Astro.redirect('/portal/admin');
}

const { data: cases } = await supabase
  .from('cases')
  .select('id, title, description, status, created_at')
  .eq('client_id', clientId)
  .order('created_at', { ascending: false });

const caseIds = (cases ?? []).map((item) => item.id);

const { data: expenses } =
  caseIds.length > 0
    ? await supabase
        .from('expenses')
        .select('id, amount, description, receipt_url, created_at, case_id, cases(title)')
        .in('case_id', caseIds)
        .order('created_at', { ascending: false })
    : { data: [] };

const { data: notes } =
  caseIds.length > 0
    ? await supabase
        .from('notes')
        .select('id, content, created_at, case_id, cases(title)')
        .in('case_id', caseIds)
        .order('created_at', { ascending: false })
    : { data: [] };

const toplamMasraf = expenses?.reduce((sum, item) => sum + Number(item.amount ?? 0), 0) ?? 0;
---

<Layout
  title="Müvekkil Detayı"
  description="Müvekkil bazlı yönetim ekranı."
  showBreadcrumbs={false}
>
  <section class="portal-admin-detail">
    <div class="container mx-auto px-4 max-w-7xl">
      
      <header class="dashboard-header" data-aos="fade-up">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div>
            <span class="post-category mb-4">Müvekkil Detayı</span>
            <h1 class="portal-h1"><span class="portal-h1-italic">{clientProfile.company_name?.split(' ')[0]}</span> {clientProfile.company_name?.split(' ').slice(1).join(' ')}</h1>
            <p class="portal-lede">Müvekkile ait kayıtları buradan yönetebilirsiniz.</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/portal/admin" class="portal-outline-link cursor-pointer">Müvekkil Listesi</a>
            <form method="POST">
              <input type="hidden" name="action" value="logout" />
              <button type="submit" class="portal-outline-link cursor-pointer hover:!text-[var(--danger)] hover:!border-[var(--danger)]">Çıkış</button>
            </form>
          </div>
        </div>
        <p class="mt-6 text-[10px] font-bold uppercase tracking-widest text-[var(--ink-faint)]">Kullanıcı adı: <span class="text-[var(--ink-strong)]">{clientProfile.username ?? '-'}</span></p>
      </header>

      {Astro.url.searchParams.get('created') === '1' && (
        <div class="portal-alert success mt-8" data-aos="fade-up">
          Müvekkil ve giriş hesabı başarıyla oluşturuldu.
        </div>
      )}

      {formState && (
        <div class:list={['portal-alert mt-8', formState.type === 'success' ? 'success' : 'danger']} data-aos="fade-up">
          {formState.message}
        </div>
      )}

      <div class="grid gap-6 md:grid-cols-3 mt-12" data-aos="fade-up">
        <div class="stat-card">
          <p class="stat-label">Toplam Dosya</p>
          <p class="stat-value">{cases?.length ?? 0}</p>
        </div>
        <div class="stat-card">
          <p class="stat-label">Toplam Masraf</p>
          <p class="stat-value">{toplamMasraf.toLocaleString('tr-TR')} <span class="text-lg">TL</span></p>
        </div>
        <div class="stat-card">
          <p class="stat-label">Toplam Not</p>
          <p class="stat-value">{notes?.length ?? 0}</p>
        </div>
      </div>

      <div class="grid gap-10 xl:grid-cols-3 mt-16">
        
        <section class="portal-card-column" data-aos="fade-up">
          <h2 class="column-title"><span class="column-title-italic">Dosya</span> Ekle</h2>
          <div class="portal-form-card">
            <form method="POST" class="portal-form">
              <input type="hidden" name="action" value="create-case" />
              <div class="form-group">
                <label for="title" class="form-label">Dosya Başlığı</label>
                <input id="title" name="title" required class="form-input" placeholder="Hukuki süreç başlığı" />
              </div>
              <div class="form-group">
                <label for="status" class="form-label">Durum</label>
                <select id="status" name="status" class="form-input">
                  <option value="Açık">Açık</option>
                  <option value="Devam ediyor">Devam ediyor</option>
                  <option value="Beklemede">Beklemede</option>
                  <option value="Kapandı">Kapandı</option>
                </select>
              </div>
              <div class="form-group">
                <label for="description" class="form-label">Açıklama</label>
                <textarea id="description" name="description" rows="4" class="form-input"></textarea>
              </div>
              <button type="submit" class="portal-submit-btn cursor-pointer">Dosya Kaydet</button>
            </form>
          </div>
        </section>

        <section class="portal-card-column" data-aos="fade-up" data-aos-delay="100">
          <h2 class="column-title"><span class="column-title-italic">Masraf</span> Ekle</h2>
          <div class="portal-form-card">
            <form method="POST" class="portal-form">
              <input type="hidden" name="action" value="create-expense" />
              <div class="form-group">
                <label for="expense_case_id" class="form-label">İlgili Dosya</label>
                <select id="expense_case_id" name="case_id" required class="form-input">
                  <option value="">Seçiniz</option>
                  {(cases ?? []).map((item) => (
                    <option value={item.id}>{item.title}</option>
                  ))}
                </select>
              </div>
              <div class="form-group">
                <label for="amount" class="form-label">Tutar (TL)</label>
                <input id="amount" name="amount" type="number" min="0" step="0.01" required class="form-input" />
              </div>
              <div class="form-group">
                <label for="expense_description" class="form-label">Açıklama</label>
                <textarea id="expense_description" name="description" rows="3" class="form-input"></textarea>
              </div>
              <div class="form-group">
                <label for="receipt_url" class="form-label">Belge URL</label>
                <input id="receipt_url" name="receipt_url" type="url" class="form-input" placeholder="https://..." />
              </div>
              <button type="submit" class="portal-submit-btn cursor-pointer">Masraf Kaydet</button>
            </form>
          </div>
        </section>

        <section class="portal-card-column" data-aos="fade-up" data-aos-delay="200">
          <h2 class="column-title"><span class="column-title-italic">Not</span> Ekle</h2>
          <div class="portal-form-card">
            <form method="POST" class="portal-form">
              <input type="hidden" name="action" value="create-note" />
              <div class="form-group">
                <label for="note_case_id" class="form-label">İlgili Dosya</label>
                <select id="note_case_id" name="case_id" required class="form-input">
                  <option value="">Seçiniz</option>
                  {(cases ?? []).map((item) => (
                    <option value={item.id}>{item.title}</option>
                  ))}
                </select>
              </div>
              <div class="form-group">
                <label for="content" class="form-label">Not İçeriği</label>
                <textarea id="content" name="content" rows="6" required class="form-input"></textarea>
              </div>
              <button type="submit" class="portal-submit-btn cursor-pointer">Not Kaydet</button>
            </form>
          </div>
        </section>

      </div>

      <div class="grid gap-10 xl:grid-cols-3 mt-20 pt-12 border-t border-[var(--border-soft)]">
        
        <section class="dashboard-column" data-aos="fade-up">
          <h2 class="column-title"><span class="column-title-italic">Kayıtlı</span> Dosyalar</h2>
          {(cases ?? []).length > 0 ? (
            <div class="space-y-4">
              {cases?.map((item) => (
                <div class="list-item-card">
                  <div class="flex justify-between items-start mb-2">
                    <h3 class="item-title">{item.title}</h3>
                    <span class="item-badge">{item.status}</span>
                  </div>
                  {item.description && <p class="item-desc">{item.description}</p>}
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-state">Henüz dosya yok.</div>
          )}
        </section>

        <section class="dashboard-column" data-aos="fade-up" data-aos-delay="100">
          <h2 class="column-title"><span class="column-title-italic">Kayıtlı</span> Masraflar</h2>
          {(expenses ?? []).length > 0 ? (
            <div class="space-y-4">
              {expenses?.map((item) => (
                <div class="list-item-card">
                  <div class="flex justify-between items-start mb-1">
                    <h3 class="item-title">{item.cases?.title ?? 'Dosya'}</h3>
                    <span class="item-price">{Number(item.amount ?? 0).toLocaleString('tr-TR')} TL</span>
                  </div>
                  {item.description && <p class="item-desc">{item.description}</p>}
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-state">Henüz masraf yok.</div>
          )}
        </section>

        <section class="dashboard-column" data-aos="fade-up" data-aos-delay="200">
          <h2 class="column-title"><span class="column-title-italic">Kayıtlı</span> Notlar</h2>
          {(notes ?? []).length > 0 ? (
            <div class="space-y-4">
              {notes?.map((item) => (
                <div class="list-item-card">
                  <h3 class="item-title mb-2">{item.cases?.title ?? 'Dosya'}</h3>
                  <p class="item-desc">{item.content}</p>
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-state">Henüz not yok.</div>
          )}
        </section>

      </div>

    </div>
  </section>
</Layout>

<style>
  .portal-admin-detail {
    background: var(--bg-base);
    padding: clamp(3rem, 7vw, 5rem) 0 clamp(4rem, 9vw, 6rem);
    min-height: 100vh;
  }

  .dashboard-header {
    border-bottom: 1px solid var(--border-soft);
    padding-bottom: 2.5rem;
  }

  .portal-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h1);
    letter-spacing: -0.022em;
    color: var(--ink-strong);
    margin: 0;
  }
  .portal-h1-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .portal-lede {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    color: var(--ink-default);
    margin-top: 1rem;
    font-weight: 300;
  }

  .post-category {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    background: var(--brand-soft);
    color: var(--brand-deep);
    border: 1px solid var(--border-soft);
    line-height: 1;
  }

  .portal-outline-link {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-strong);
    transition: all 200ms ease;
  }
  .portal-outline-link:hover {
    background: var(--brand-soft);
    border-color: var(--brand);
    color: var(--brand-deep);
  }

  /* STATS */
  .stat-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .stat-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }
  .stat-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 2.5rem;
    color: var(--ink-strong);
    line-height: 1;
  }

  /* FORMS */
  .column-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: -0.015em;
    color: var(--ink-strong);
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .column-title-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .portal-form-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  .portal-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .form-input {
    width: 100%;
    padding: 12px 14px;
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--ink-strong);
    outline: none;
    transition: all 200ms ease;
  }
  .form-input:focus { border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-soft); }

  .portal-submit-btn {
    width: 100%;
    padding: 14px;
    background: var(--brand-deep);
    color: white;
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: all 200ms ease;
  }
  .portal-submit-btn:hover { background: var(--ink-strong); transform: translateY(-1px); box-shadow: var(--shadow-sm); }

  /* LISTS */
  .list-item-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    transition: all 200ms ease;
  }
  .list-item-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--brand); }
  .item-title { font-family: var(--font-display); font-weight: 500; font-size: 1rem; color: var(--ink-strong); }
  .item-badge {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 0.2rem 0.4rem;
    background: var(--brand-soft);
    color: var(--brand-deep);
    border-radius: 4px;
  }
  .item-price { font-family: var(--font-sans); font-weight: 600; font-size: 0.875rem; color: var(--brand-deep); }
  .item-desc { font-family: var(--font-sans); font-size: 0.8125rem; color: var(--ink-muted); margin-top: 0.25rem; }

  .portal-alert { padding: 1rem; border-radius: var(--radius-md); font-size: 0.875rem; text-align: center; font-weight: 500; }
  .portal-alert.success { background: rgba(107, 142, 78, 0.08); color: var(--success); border: 1px solid rgba(107, 142, 78, 0.15); }
  .portal-alert.danger { background: rgba(168, 68, 42, 0.08); color: var(--danger); border: 1px solid rgba(168, 68, 42, 0.15); }

  .empty-state { padding: 2rem; border: 1px dashed var(--border); border-radius: var(--radius-md); text-align: center; color: var(--ink-faint); font-size: 0.8125rem; font-family: var(--font-sans); }
</style>
