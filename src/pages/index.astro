---
import Layout from '../layouts/Layout.astro';
import KeyServices from '../components/KeyServices.astro';
import LatestPosts from '../components/LatestPosts.astro';

// ARKA PLAN RESMİ AYARLARI
// 1. Masaüstü (PC) için resim:
const desktopImage = "/ana-resim.jpg";

// 2. Mobil (Telefon) için resim:
// (Eğer mobilde farklı resim olsun isterseniz buraya o resmin yolunu yazın. Örnek: "/mobil-resim.jpg")
const mobileImage = "/ana-resim.jpg";
---

<Layout title="İzmir Avukatlık ve Hukuki Danışmanlık" description="Dişçi Hukuk Bürosu, İzmir merkezli ceza, aile, iş, kira, gayrimenkul ve ticaret hukuku alanlarında dava takibi ve kurumsal hukuki danışmanlık hizmeti sunar." canonicalPath="/" enableAOS={true} showBreadcrumbs={false}>

    <section class="hero relative h-screen w-full flex items-center justify-center overflow-hidden">

        <div class="absolute inset-0 z-0">
            <picture>
                <source media="(max-width: 768px)" srcset={mobileImage} />
                <source media="(min-width: 769px)" srcset={desktopImage} />
                <img
                    src={desktopImage}
                    alt="Legal Architecture Background"
                    class="w-full h-full object-cover hero-image"
                />
            </picture>
            <div class="absolute inset-0 hero-overlay"></div>
            <div class="hero-warm-glow" aria-hidden="true"></div>
        </div>

        <div class="relative z-10 container mx-auto px-4 text-center" data-aos="fade-up" data-aos-duration="1500">

            <figure class="max-w-4xl mx-auto">
                <blockquote class="hero-quote">
                    "Hukuk, <br />
                    <span class="hero-accent">tutkudan arınmış</span> <br />
                    akıldır."
                </blockquote>
                <figcaption class="hero-caption">
                    <span class="hero-rule" aria-hidden="true"></span>
                    Aristoteles
                    <span class="hero-rule" aria-hidden="true"></span>
                </figcaption>
            </figure>

        </div>

        <div class="hero-scroll absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
            <span class="hero-scroll-label">Keşfet</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
        </div>

    </section>

    <KeyServices />
    <LatestPosts />

</Layout>

<style>
    .hero {
        background: var(--bg-base);
    }

    .hero-image {
        opacity: 0.28;
        filter: grayscale(0.55) sepia(0.06);
    }

    .hero-overlay {
        background: linear-gradient(
            to bottom,
            color-mix(in srgb, var(--bg-base) 65%, transparent),
            color-mix(in srgb, var(--bg-base) 80%, transparent),
            var(--bg-base)
        );
    }

    .hero-warm-glow {
        position: absolute;
        top: -120px;
        right: -160px;
        width: 480px;
        height: 480px;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(237, 224, 196, 0.42) 0%,
            rgba(237, 224, 196, 0.18) 40%,
            transparent 70%
        );
        pointer-events: none;
        filter: blur(8px);
    }

    .hero-quote {
        font-family: var(--font-display);
        font-weight: 400;
        font-style: normal;
        font-size: clamp(2.5rem, 6vw + 1rem, 4.75rem);
        line-height: 1.05;
        letter-spacing: -0.022em;
        color: var(--ink-strong);
        font-variation-settings: "opsz" 144;
    }

    .hero-accent {
        font-family: var(--font-display);
        font-style: italic;
        font-weight: 400;
        font-variation-settings: "SOFT" 100, "opsz" 144;
        color: var(--brand-deep);
    }

    .hero-caption {
        margin-top: 2.5rem;
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 0.75rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--ink-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
    }

    .hero-rule {
        width: 2.5rem;
        height: 1px;
        background: var(--border);
    }

    .hero-scroll {
        opacity: 0.55;
        animation: hero-scroll-bounce 2.4s ease-in-out infinite;
        color: var(--ink-muted);
    }
    .hero-scroll-label {
        font-family: var(--font-sans);
        font-size: 0.625rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        font-weight: 500;
    }

    @keyframes hero-scroll-bounce {
        0%, 100% { transform: translate(-50%, 0); }
        50% { transform: translate(-50%, 8px); }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-scroll { animation: none; }
    }
</style>
