---
import Layout from '../layouts/Layout.astro';
import KeyServices from '../components/KeyServices.astro';
import LatestPosts from '../components/LatestPosts.astro';

// ARKA PLAN RESMİ AYARLARI
// 1. Masaüstü (PC) için resim:
const desktopImage = "/ana-resim.jpg";

// 2. Mobil (Telefon) için resim:
// (Eğer mobilde farklı resim olsun isterseniz buraya o resmin yolunu yazın. Örnek: "/mobil-resim.jpg")
const mobileImage = "/ana-resim.jpg";
---

<Layout title="İzmir Avukatlık ve Hukuki Danışmanlık" description="Dişçi Hukuk Bürosu, İzmir merkezli ceza, aile, iş, kira, gayrimenkul ve ticaret hukuku alanlarında dava takibi ve kurumsal hukuki danışmanlık hizmeti sunar." canonicalPath="/" enableAOS={true} showBreadcrumbs={false}>

    <section class="relative h-screen w-full flex items-center justify-center overflow-hidden" style="background: var(--bg);">

        <div class="absolute inset-0 z-0">
            <picture>
                <!-- Mobil İçin -->
                <source media="(max-width: 768px)" srcset={mobileImage} />
                <!-- Masaüstü İçin -->
                <source media="(min-width: 769px)" srcset={desktopImage} />
                <!-- Varsayılan -->
                <img
                    src={desktopImage}
                    alt="Legal Architecture Background"
                    class="w-full h-full object-cover hero-image grayscale"
                />
            </picture>
            <div class="absolute inset-0 hero-overlay"></div>
        </div>

        <div class="relative z-10 container mx-auto px-4 text-center" data-aos="fade-up" data-aos-duration="1500">

            <figure class="max-w-4xl mx-auto">
                <blockquote class="text-4xl md:text-6xl lg:text-7xl font-bold font-display leading-tight tracking-tight" style="color: var(--text);">
                    "Hukuk, <br />
                    <span class="text-gold-500 drop-shadow-sm">tutkudan arınmış</span> <br />
                    akıldır."
                </blockquote>
                <figcaption class="mt-8 text-lg md:text-xl font-light tracking-widest uppercase flex items-center justify-center gap-4" style="color: var(--text-3);">
                    <span class="w-8 h-px" style="background: var(--border);"></span>
                    Aristoteles
                    <span class="w-8 h-px" style="background: var(--border);"></span>
                </figcaption>
            </figure>



        </div>

        <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 flex flex-col items-center gap-2 opacity-50 animate-bounce">
            <span class="text-[10px] tracking-widest uppercase" style="color: var(--text-3);">Keşfet</span>
            <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
        </div>

    </section>

    <KeyServices />
    <LatestPosts />

</Layout>

<style>
    .hero-image {
        opacity: 0.45;
    }
    :global([data-theme="dark"]) .hero-image {
        opacity: 0.25;
    }

    .hero-overlay {
        background: linear-gradient(to bottom,
            color-mix(in srgb, var(--bg) 70%, transparent),
            color-mix(in srgb, var(--bg) 55%, transparent),
            var(--bg)
        );
    }
    :global([data-theme="dark"]) .hero-overlay {
        background: linear-gradient(to bottom,
            color-mix(in srgb, var(--bg) 90%, transparent),
            color-mix(in srgb, var(--bg) 75%, transparent),
            var(--bg)
        );
    }

    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
