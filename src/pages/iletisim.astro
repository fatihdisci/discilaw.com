---
import Layout from '../layouts/Layout.astro';
import { InteractiveMap } from '../components/InteractiveMap';
---

<Layout title="İletişim | Dişçi Hukuk Bürosu" description="Dişçi Hukuk Bürosu iletişim bilgileri, adres ve ulaşım detayları. Hukuki danışmanlık ve randevu talepleriniz için bize ulaşın." enableAOS={true}>
  <section class="contact-hero">
    <div class="container mx-auto px-4 text-center">
      <h1 class="contact-hero-title" data-aos="fade-up">
        <span class="contact-hero-title-italic">İletişim</span>
      </h1>
      <p class="contact-hero-lede" data-aos="fade-up" data-aos-delay="100">
        Sorularınız veya danışmanlık talepleriniz için bize ulaşın.
      </p>
    </div>
  </section>

  <section class="contact-body">
    <div class="container mx-auto px-4">
      <div class="contact-shell">
        <div class="contact-grid">

          <!-- Contact Info (Left) -->
          <aside class="contact-info" data-aos="fade-right">
            <div class="contact-info-glow" aria-hidden="true"></div>

            <div class="relative z-10">
              <h3 class="contact-info-title">İletişim Bilgileri</h3>

              <div class="contact-info-list">
                <div class="contact-info-item">
                  <span class="contact-info-icon">
                    <svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                  </span>
                  <div>
                    <h4 class="contact-info-label">Adres</h4>
                    <p class="contact-info-value">Tuna Mah. 1690. Sk. No:1 K:6 D:601<br/>Karşıyaka / İzmir</p>
                  </div>
                </div>

                <div class="contact-info-item">
                  <span class="contact-info-icon">
                    <svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                  </span>
                  <div>
                    <h4 class="contact-info-label">Telefon</h4>
                    <a href="tel:+905077247735" class="contact-info-value contact-info-link cursor-pointer">+90 (507) 724 77 35</a>
                  </div>
                </div>

                <div class="contact-info-item">
                  <span class="contact-info-icon">
                    <svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                  </span>
                  <div>
                    <h4 class="contact-info-label">E-posta</h4>
                    <a href="mailto:info@discilaw.com" class="contact-info-value contact-info-link cursor-pointer">info@discilaw.com</a>
                  </div>
                </div>
              </div>
            </div>

            <div class="contact-socials relative z-10">
              <p class="contact-info-label">Bizi Takip Edin</p>
              <div class="contact-socials-row">
                <a href="https://www.instagram.com/discihukukburosu/" target="_blank" rel="noopener noreferrer" class="contact-social cursor-pointer" aria-label="Instagram">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="5"/>
                    <circle cx="12" cy="12" r="4"/>
                    <circle cx="17.5" cy="6.5" r="0.9" fill="currentColor" stroke="none"/>
                  </svg>
                </a>
              </div>
            </div>
          </aside>

          <!-- Map & Form (Right) -->
          <div class="contact-main" data-aos="fade-left">
            <div class="contact-map">
              <InteractiveMap
                client:load
                address="Dişçi Hukuk Bürosu - Karşıyaka/İzmir"
                googleMapsUrl="https://maps.app.goo.gl/ZWmAFfKGK7YBwWsZ6"
                embedUrl="https://maps.google.com/maps?q=38.456222,27.118806&hl=tr&z=17&output=embed"
              />
            </div>

            <div class="contact-form-wrap">
              <h3 class="contact-form-title"><span class="contact-form-title-italic">Bize</span> Ulaşın</h3>
              <form action="https://api.web3forms.com/submit" method="POST" class="contact-form">
                <input type="hidden" name="access_key" value="805821df-be8d-4859-b4e6-d75e56dedcb7">
                <input type="hidden" name="subject" value="Discilaw Web Sitesi - Yeni Mesaj">
                <input type="hidden" name="from_name" value="Discilaw İletişim Formu">
                <input type="hidden" name="redirect" value="https://discilaw.com/iletisim?success=true">
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div>
                    <label for="name" class="contact-label">Adınız Soyadınız</label>
                    <input type="text" name="name" id="name" required class="contact-input" placeholder="Adınız Soyadınız">
                  </div>
                  <div>
                    <label for="email" class="contact-label">E-posta Adresiniz</label>
                    <input type="email" name="email" id="email" required class="contact-input" placeholder="ornek@email.com">
                  </div>
                </div>

                <div>
                  <label for="message" class="contact-label">Mesajınız</label>
                  <textarea name="message" id="message" rows="5" required class="contact-input contact-textarea" placeholder="Mesajınızı buraya yazabilirsiniz..."></textarea>
                </div>

                <button type="submit" class="contact-submit cursor-pointer">
                  Mesajı Gönder
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </button>
              </form>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-soft);
    padding: clamp(3.5rem, 8vw, 5.5rem) 0;
  }
  .contact-hero-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h1);
    line-height: 1.05;
    letter-spacing: -0.022em;
    color: var(--ink-strong);
    margin-bottom: 1.25rem;
  }
  .contact-hero-title-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }
  .contact-hero-lede {
    max-width: 36rem;
    margin: 0 auto;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--ink-default);
  }

  .contact-body {
    background: var(--bg-base);
    padding: clamp(3.5rem, 8vw, 5.5rem) 0;
  }

  .contact-shell {
    max-width: 1200px;
    margin: 0 auto;
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .contact-grid {
    display: flex;
    flex-direction: column;
  }
  @media (min-width: 1024px) {
    .contact-grid { flex-direction: row; }
  }

  /* INFO PANEL */
  .contact-info {
    position: relative;
    overflow: hidden;
    width: 100%;
    padding: clamp(2rem, 4vw, 3rem);
    background: var(--bg-elevated);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .contact-info {
      width: 36%;
      min-height: 100%;
      border-right: 1px solid var(--border-soft);
    }
  }
  .contact-info-glow {
    display: none;
  }

  .contact-info-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: 1.625rem;
    letter-spacing: -0.018em;
    color: var(--ink-strong);
    margin-bottom: 2rem;
    font-variation-settings: "SOFT" 100, "opsz" 144;
  }

  .contact-info-list {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .contact-info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .contact-info-icon {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: var(--brand-soft);
    border: 1px solid var(--border-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-deep);
  }
  .contact-info-icon svg {
    width: 18px;
    height: 18px;
  }

  .contact-info-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.4rem;
  }

  .contact-info-value {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--ink-strong);
    margin: 0;
  }

  .contact-info-link {
    display: inline-block;
    color: var(--ink-strong);
    transition: color 200ms ease;
  }
  .contact-info-link:hover { color: var(--brand-deep); }

  .contact-socials { display: flex; flex-direction: column; }
  .contact-socials-row {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
  .contact-social {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-pill);
    background: var(--bg-base);
    border: 1px solid var(--border-soft);
    color: var(--ink-default);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 200ms ease, color 200ms ease, border-color 200ms ease, transform 200ms ease;
  }
  .contact-social:hover {
    background: var(--brand-soft);
    color: var(--brand-deep);
    border-color: var(--brand);
    transform: translateY(-1px);
  }
  .contact-social svg { width: 18px; height: 18px; }

  /* MAIN PANEL */
  .contact-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .contact-map {
    width: 100%;
    border-bottom: 1px solid var(--border-soft);
  }

  .contact-form-wrap {
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }

  .contact-form-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.625rem;
    letter-spacing: -0.018em;
    color: var(--ink-strong);
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }
  .contact-form-title-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-label {
    display: block;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    color: var(--ink-default);
    margin-bottom: 0.5rem;
  }

  .contact-input {
    width: 100%;
    height: 48px;
    padding: 0 14px;
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--ink-strong);
    transition: border-color 200ms ease, box-shadow 200ms ease;
    outline: none;
  }
  .contact-input::placeholder {
    color: var(--ink-faint);
    font-style: italic;
    font-weight: 300;
  }
  .contact-input:focus {
    border-color: var(--brand);
    box-shadow: 0 0 0 3px var(--brand-soft);
  }

  .contact-textarea {
    height: auto;
    padding: 14px;
    line-height: 1.55;
    resize: vertical;
    min-height: 120px;
  }

  .contact-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 14px 26px;
    background: var(--ink-strong);
    color: var(--bg-base);
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
    margin-top: 0.5rem;
  }
  .contact-submit:hover {
    background: var(--brand-deep);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }
  .contact-submit svg { transition: transform 220ms ease; }
  .contact-submit:hover svg { transform: translateX(4px); }
</style>
