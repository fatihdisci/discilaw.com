---
import Layout from '../layouts/Layout.astro';
import { InteractiveMap } from '../components/InteractiveMap';
---

<Layout title="İletişim | Dişçi Hukuk Bürosu" description="Dişçi Hukuk Bürosu iletişim bilgileri, adres ve ulaşım detayları. Hukuki danışmanlık ve randevu talepleriniz için bize ulaşın.">
  <!-- Header -->
  <section class="py-20 border-b" style="background: var(--bg-2); border-color: var(--border);">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-light font-display mb-4" style="color: var(--text);" data-aos="fade-up">İletişim</h1>
      <p class="max-w-2xl mx-auto" style="color: var(--text-2);" data-aos="fade-up" data-aos-delay="100">
        Sorularınız veya danışmanlık talepleriniz için bize ulaşın.
      </p>
    </div>
  </section>

  <section class="py-24" style="background: var(--bg);">
    <div class="container mx-auto px-4">
      <div class="max-w-7xl mx-auto rounded-3xl overflow-hidden shadow-2xl border" style="background: var(--bg-2); border-color: var(--border);">
        <div class="flex flex-col lg:flex-row">

          <!-- Contact Info (Left) -->
          <div class="w-full lg:w-1/3 p-12 relative overflow-hidden flex flex-col justify-between" style="background: var(--bg-3);" data-aos="fade-right">
            <!-- Decorative circle -->
            <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-gold-500/10 blur-3xl"></div>

            <div class="relative z-10">
                <h3 class="text-2xl font-bold mb-8 font-display" style="color: var(--text);">İletişim Bilgileri</h3>

                <div class="space-y-8">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background: var(--bg-2);">
                        <svg class="w-5 h-5" style="color: var(--text-3);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </div>
                    <div>
                    <h4 class="font-semibold mb-1" style="color: var(--text);">Adres</h4>
                    <p class="text-sm font-light" style="color: var(--text-2);">Tuna Mah. 1690. Sk. No:1 K:6 D:601<br/>Karşıyaka / İzmir</p>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background: var(--bg-2);">
                        <svg class="w-5 h-5" style="color: var(--text-3);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                        </svg>
                    </div>
                    <div>
                    <h4 class="font-semibold mb-1" style="color: var(--text);">Telefon</h4>
                    <a href="tel:+905077247735" class="hover:text-gold-500 transition-colors text-sm font-light" style="color: var(--text-2);">+90 (507) 724 77 35</a>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background: var(--bg-2);">
                        <svg class="w-5 h-5" style="color: var(--text-3);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                    <h4 class="font-semibold mb-1" style="color: var(--text);">Email</h4>
                    <a href="mailto:info@discilaw.com" class="hover:text-gold-500 transition-colors text-sm font-light" style="color: var(--text-2);">info@discilaw.com</a>
                    </div>
                </div>
                </div>
            </div>

            <!-- Socials -->
             <div class="mt-12 relative z-10">
                <p class="font-semibold mb-4" style="color: var(--text);">Bizi Takip Edin</p>
                <div class="flex gap-4">
                    <a href="https://www.instagram.com/discihukukburosu/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-gradient-to-br hover:from-purple-600 hover:via-pink-500 hover:to-gold-500 hover:text-white transition-all" style="background: var(--bg-2); color: var(--text-3);" aria-label="Instagram">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </a>
                </div>
            </div>

          </div>

          <!-- Map & Form (Right) -->
          <div class="w-full lg:w-2/3" data-aos="fade-left">
            <!-- Interactive Map -->
            <div class="w-full">
                <InteractiveMap
                  client:load
                  address="Dişçi Hukuk Bürosu - Karşıyaka/İzmir"
                  googleMapsUrl="https://maps.app.goo.gl/ZWmAFfKGK7YBwWsZ6"
                  embedUrl="https://maps.google.com/maps?q=38.4563223211955,27.118845615342106&hl=tr&z=17&output=embed"
                />
            </div>

            <!-- Form -->
            <div class="p-8 lg:p-12">
                 <h3 class="text-2xl font-bold mb-6 font-display" style="color: var(--text);">Bize Ulaşın</h3>
                <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
                    <input type="hidden" name="access_key" value="805821df-be8d-4859-b4e6-d75e56dedcb7">
                    <input type="hidden" name="subject" value="Discilaw Web Sitesi - Yeni Mesaj">
                    <input type="hidden" name="from_name" value="Discilaw İletişim Formu">
                    <input type="hidden" name="redirect" value="https://www.discilaw.com/iletisim?success=true">
                    <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="name" class="block text-sm font-medium mb-2" style="color: var(--text-2);">Adınız Soyadınız</label>
                            <input type="text" name="name" id="name" required class="w-full h-12 px-4 rounded-lg border focus:outline-none focus:border-gold-500 focus:ring-1 focus:ring-gold-500 transition-all" style="background: var(--bg); border-color: var(--border); color: var(--text);" placeholder="Adınız Soyadınız">
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-medium mb-2" style="color: var(--text-2);">E-posta Adresiniz</label>
                            <input type="email" name="email" id="email" required class="w-full h-12 px-4 rounded-lg border focus:outline-none focus:border-gold-500 focus:ring-1 focus:ring-gold-500 transition-all" style="background: var(--bg); border-color: var(--border); color: var(--text);" placeholder="ornek@email.com">
                        </div>
                    </div>

                    <div>
                        <label for="message" class="block text-sm font-medium mb-2" style="color: var(--text-2);">Mesajınız</label>
                        <textarea name="message" id="message" rows="4" required class="w-full p-4 rounded-lg border focus:outline-none focus:border-gold-500 focus:ring-1 focus:ring-gold-500 transition-all resize-none" style="background: var(--bg); border-color: var(--border); color: var(--text);" placeholder="Mesajınızı buraya yazabilirsiniz..."></textarea>
                    </div>

                    <button type="submit" class="w-full py-4 bg-gold-500 hover:bg-gold-600 font-bold rounded-lg transition-all shadow-lg shadow-gold-500/20 active:scale-[0.98]" style="color: var(--bg);">
                        MESAJI GÖNDER
                    </button>
                </form>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>
</Layout>
