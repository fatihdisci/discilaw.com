---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ServiceIcon } from '../components/ServiceIcon';
import { getSiteUrl } from '../lib/seo';

const services = await getCollection('services');
const sortedServices = services.sort((a, b) => a.data.title.localeCompare(b.data.title, 'tr'));

const origin = getSiteUrl(Astro.site).origin;

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${origin}/hakkimizda#aboutpage`,
  url: `${origin}/hakkimizda`,
  name: 'Hakkımızda',
  inLanguage: 'tr-TR',
  isPartOf: { '@id': `${origin}/#website` },
  about: { '@id': `${origin}/#organization` },
  mainEntity: { '@id': `${origin}/#attorney` },
};
---

<Layout
  title="Hakkımızda"
  description="Av. Fatih Dişçi tarafından kurulan Dişçi Hukuk Bürosu; Yalova Üniversitesi Hukuk Fakültesi 2020 mezunu, İzmir Barosu'na 17695 sicil numarası ile kayıtlı avukat tarafından İzmir Karşıyaka'da hukuki danışmanlık ve dava takibi yürütmektedir."
  canonicalPath="/hakkimizda"
  enableAOS={true}
  breadcrumbItems={[{ name: 'Hakkımızda', href: '/hakkimizda' }]}
  structuredData={aboutPageSchema}
>
  <article class="about-article">
    <!-- HERO -->
    <section class="container mx-auto px-4 max-w-5xl about-hero" data-aos="fade-up">
      <div class="about-hero-grid">
        <div class="about-photo-wrap">
          <img
            src="/profile.png"
            alt="Av. Fatih Dişçi — İzmir Barosu Sicil No 17695"
            width="480"
            height="480"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="about-photo"
          />
        </div>

        <div class="about-hero-text">
          <span class="about-eyebrow">İzmir Barosu — Sicil No 17695</span>
          <h1 class="about-h1">
            Av. <span class="about-h1-italic">Fatih Dişçi</span>
          </h1>
          <p class="about-lede">
            2020 yılında Yalova Üniversitesi Hukuk Fakültesi'nden mezun olan Av. Fatih Dişçi,
            2021 yılından itibaren İzmir Karşıyaka'da avukatlık faaliyetini sürdürmektedir.
            Bu doğrultuda kurulan Dişçi Hukuk Bürosu; hukuki uyuşmazlıkların önlenmesi ve çözümü
            süreçlerinde gerçek ve tüzel kişilere avukatlık ve danışmanlık hizmeti sunmaktadır.
          </p>
        </div>
      </div>
    </section>

    <!-- BİYOGRAFİ -->
    <section class="container mx-auto px-4 max-w-3xl about-section" data-aos="fade-up">
      <h2 class="about-h2"><span class="about-h2-italic">Kısaca</span> büro hakkında</h2>
      <div class="about-prose">
        <p>
          Dişçi Hukuk Bürosu, Av. Fatih Dişçi tarafından İzmir Karşıyaka'da kurulmuş bir
          avukatlık bürosudur. Büromuz; Türk Medeni Kanunu, Türk Ceza Kanunu, İş Kanunu,
          Türk Borçlar Kanunu, Türk Ticaret Kanunu ve ilgili mevzuat çerçevesinde
          danışmanlık ve dava takibi yapmaktadır.
        </p>
        <p>
          Müvekkillere; uyuşmazlığın hukuki niteliği, mevzuat ve içtihat çerçevesinde objektif
          bir değerlendirme sunulması, süreç içinde yapılacak işlemler ile olası senaryoların
          önceden paylaşılması esas alınır. Dava ve takip süreçlerinde dosyalar dijital ortamda
          yönetilir; UYAP üzerinden yapılan işlemler ve önemli gelişmeler müvekkile düzenli
          olarak iletilir.
        </p>
      </div>
    </section>

    <!-- FAALİYET ALANLARI -->
    <section class="container mx-auto px-4 max-w-5xl about-section" data-aos="fade-up">
      <h2 class="about-h2"><span class="about-h2-italic">Faaliyet</span> alanları</h2>
      <p class="about-section-lede">
        Aşağıdaki alanlarda hukuki danışmanlık ve dava takibi yapılmaktadır. Her bir alan için
        detaylı bilgiye ilgili çalışma alanı sayfasından ulaşılabilir.
      </p>

      <ul class="about-areas-grid">
        {sortedServices.map((s) => (
          <li>
            <a href={`/calisma-alanlarimiz/${s.slug}`} class="about-area-card cursor-pointer">
              <span class="about-area-icon">
                <ServiceIcon client:visible slug={s.slug} size={22} />
              </span>
              <span class="about-area-text">
                <span class="about-area-title">{s.data.title}</span>
                <span class="about-area-desc">{s.data.description}</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- ÇALIŞMA PRENSİPLERİ -->
    <section class="container mx-auto px-4 max-w-3xl about-section" data-aos="fade-up">
      <h2 class="about-h2"><span class="about-h2-italic">Çalışma</span> prensipleri</h2>
      <ul class="about-principles">
        <li class="about-principle">
          <span class="about-principle-num">01</span>
          <div>
            <h3 class="about-principle-title">Mevzuata ve içtihada dayalı görüş</h3>
            <p class="about-principle-text">
              Müvekkile sunulan değerlendirmeler; yürürlükteki mevzuat, Yargıtay ve Anayasa
              Mahkemesi içtihatları çerçevesinde, garanti veya kesinlik içeren ifadelerden
              kaçınılarak hazırlanır.
            </p>
          </div>
        </li>
        <li class="about-principle">
          <span class="about-principle-num">02</span>
          <div>
            <h3 class="about-principle-title">Şeffaf süreç bildirimi</h3>
            <p class="about-principle-text">
              Dava ve takip süreçlerinde; duruşma tarihleri, ara kararlar, tebligatlar ve önemli
              gelişmeler düzenli olarak müvekkile iletilir; vekalet ücreti ve masraflar baştan
              yazılı şekilde belirlenir.
            </p>
          </div>
        </li>
        <li class="about-principle">
          <span class="about-principle-num">03</span>
          <div>
            <h3 class="about-principle-title">Mesleki sır ve gizlilik</h3>
            <p class="about-principle-text">
              Avukatlık Kanunu m.36 ve TBB Meslek Kuralları kapsamında, müvekkile ilişkin
              bilgilerin gizliliği esas alınır; üçüncü kişilere yalnızca yazılı muvafakat
              halinde paylaşım yapılır.
            </p>
          </div>
        </li>
        <li class="about-principle">
          <span class="about-principle-num">04</span>
          <div>
            <h3 class="about-principle-title">Dijital dosya yönetimi</h3>
            <p class="about-principle-text">
              Dosyalar dijital ortamda saklanır; UYAP üzerindeki işlemler ve gelen tebligatlar
              eşzamanlı olarak takip edilerek hak düşürücü ve zamanaşımı sürelerine ilişkin
              riskler azaltılır.
            </p>
          </div>
        </li>
      </ul>
    </section>

    <!-- BÜRO BİLGİLERİ -->
    <section class="container mx-auto px-4 max-w-5xl about-section" data-aos="fade-up">
      <h2 class="about-h2"><span class="about-h2-italic">Büro</span> bilgileri</h2>

      <div class="about-info-grid">
        <div class="about-info-card">
          <h3 class="about-info-title">Adres</h3>
          <p class="about-info-text">
            Tuna Mah. 1690. Sk. Doktorlar İş Hanı<br />
            No: 1 Kat: 6 Daire: 601<br />
            Karşıyaka / İzmir
          </p>
          <a
            href="https://www.google.com/maps/dir/?api=1&destination=38.456222,27.118806"
            target="_blank"
            rel="noopener"
            class="about-info-link"
          >
            Yol Tarifi Al →
          </a>
        </div>

        <div class="about-info-card">
          <h3 class="about-info-title">Çalışma Saatleri</h3>
          <p class="about-info-text">
            Pazartesi – Cuma · 09:00 – 18:00<br />
            Cumartesi – Pazar · Kapalı
          </p>
          <p class="about-info-note">Görüşmeler önceden randevu ile yapılmaktadır.</p>
        </div>

        <div class="about-info-card">
          <h3 class="about-info-title">İletişim</h3>
          <p class="about-info-text">
            <a href="tel:+905077247735" class="about-info-link-inline">0 (507) 724 77 35</a><br />
            <a href="mailto:info@discilaw.com" class="about-info-link-inline">info@discilaw.com</a>
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="container mx-auto px-4 max-w-3xl about-section about-cta-section" data-aos="fade-up">
      <h2 class="about-cta-title">
        Hukuki bir <span class="about-h2-italic">değerlendirmeye</span> ihtiyacınız mı var?
      </h2>
      <p class="about-cta-text">
        Dosyanıza ilişkin görüşme talepleriniz için iletişim formu üzerinden ulaşabilirsiniz.
      </p>
      <a href="/iletisim" class="about-cta-button cursor-pointer">İletişime Geç</a>
    </section>
  </article>
</Layout>

<style>
  .about-article {
    background: var(--bg-base);
    padding: clamp(2rem, 5vw, 3.5rem) 0 clamp(4rem, 9vw, 6rem);
  }

  /* HERO */
  .about-hero {
    margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
  }
  .about-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.75rem, 4vw, 3rem);
    align-items: center;
  }
  @media (min-width: 768px) {
    .about-hero-grid {
      grid-template-columns: minmax(260px, 320px) 1fr;
    }
  }

  .about-photo-wrap {
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-md);
    background: var(--bg-elevated);
  }
  .about-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-eyebrow {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--brand-deep);
    margin-bottom: 1rem;
  }
  .about-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h1);
    line-height: 1.05;
    letter-spacing: -0.022em;
    color: var(--ink-strong);
    margin: 0 0 1rem 0;
  }
  .about-h1-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }
  .about-lede {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--ink-default);
    margin: 0;
  }

  /* SECTIONS */
  .about-section {
    margin-top: clamp(2.5rem, 6vw, 4rem);
  }
  .about-h2 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h2);
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--ink-strong);
    margin-bottom: 1.25rem;
  }
  .about-h2-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }
  .about-section-lede {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-muted);
    margin-bottom: 1.75rem;
  }

  .about-prose p {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--ink-default);
    margin-bottom: 1rem;
  }

  /* FAALİYET ALANLARI */
  .about-areas-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.875rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .about-areas-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .about-areas-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .about-area-card {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 1rem 1.125rem;
    transition: border-color 240ms ease, transform 240ms ease, box-shadow 240ms ease;
    height: 100%;
  }
  .about-area-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .about-area-icon {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--brand-soft);
    color: var(--brand-deep);
  }
  .about-area-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .about-area-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    color: var(--ink-strong);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }
  .about-area-desc {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--ink-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* PRENSİPLER */
  .about-principles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
  }
  .about-principle {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 1rem;
    padding: 1.25rem 1.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
  }
  .about-principle-num {
    font-family: var(--font-display);
    font-style: italic;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    font-size: 1.5rem;
    color: var(--brand-deep);
    line-height: 1;
  }
  .about-principle-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.125rem;
    color: var(--ink-strong);
    margin: 0 0 0.4rem 0;
    line-height: 1.3;
  }
  .about-principle-text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ink-default);
    margin: 0;
  }

  /* INFO */
  .about-info-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .about-info-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .about-info-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.25rem;
  }
  .about-info-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--brand-deep);
    margin: 0 0 0.75rem 0;
  }
  .about-info-text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--ink-default);
    margin: 0;
  }
  .about-info-note {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--ink-muted);
    margin-top: 0.5rem;
    font-style: italic;
  }
  .about-info-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--brand-deep);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }
  .about-info-link:hover { color: var(--ink-strong); }
  .about-info-link-inline {
    color: var(--ink-default);
    transition: color 200ms ease;
  }
  .about-info-link-inline:hover { color: var(--brand-deep); }

  /* CTA */
  .about-cta-section {
    text-align: center;
    padding-top: clamp(2.5rem, 5vw, 3.5rem);
    border-top: 1px solid var(--border-soft);
  }
  .about-cta-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h2);
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--ink-strong);
    margin: 0 0 0.875rem 0;
  }
  .about-cta-text {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    color: var(--ink-muted);
    margin: 0 0 1.75rem 0;
  }
  .about-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    background: var(--ink-strong);
    color: var(--bg-base);
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    transition: background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .about-cta-button:hover {
    background: var(--brand-deep);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }
</style>
