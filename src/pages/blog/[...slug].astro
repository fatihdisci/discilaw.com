---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ShareButton from '../../components/ShareButton';
import { toAbsoluteUrl } from '../../lib/seo';
import { getRelatedPosts } from '../../lib/blog';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allPosts = await getCollection('blog');
const relatedPosts = getRelatedPosts(entry, allPosts, 4);
const wordCount = entry.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
const canonicalPath = `/blog/${entry.slug}`;
const canonical = toAbsoluteUrl(canonicalPath, Astro.site);
const imageUrl = toAbsoluteUrl(entry.data.image, Astro.site);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  image: [imageUrl],
  author: {
    '@type': 'Person',
    name: entry.data.author || 'Av. Fatih Dişçi',
    url: toAbsoluteUrl('/', Astro.site),
  },
  publisher: {
    '@type': 'Organization',
    name: 'Dişçi Hukuk Bürosu',
    logo: { '@type': 'ImageObject', url: toAbsoluteUrl('/logo.png', Astro.site) },
  },
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.updatedDate || entry.data.pubDate).toISOString(),
  articleSection: entry.data.category || 'Genel',
  keywords: (entry.data.tags || []).join(', '),
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  canonicalPath={canonicalPath}
  pageType="article"
  enableAOS={true}
  breadcrumbItems={[{ name: 'Blog', href: '/blog' }, { name: entry.data.title, href: canonicalPath }]}
  structuredData={articleSchema}
>
  <article class="py-24 bg-slate-950 min-h-screen">
    <div class="container mx-auto px-4 max-w-4xl mb-12 text-center" data-aos="fade-up">
      <div class="mb-6 flex items-center justify-center gap-4 text-sm flex-wrap">
        <span class="text-gold-500 font-bold px-3 py-1 rounded-full bg-gold-500/10 border border-gold-500/20">{entry.data.category}</span>
        <span class="text-slate-500">•</span>
        <time class="text-slate-400">{entry.data.pubDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span class="text-slate-500">•</span>
        <span class="text-slate-400">{readingTime} dk okuma</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-8 leading-tight">{entry.data.title}</h1>
      {entry.data.image && <img src={entry.data.image} alt={entry.data.title} width="1280" height="720" loading="eager" fetchpriority="high" decoding="async" class="w-full h-auto object-cover max-h-[500px] rounded-2xl overflow-hidden shadow-2xl border border-white/10 mb-12" />}
    </div>

    <div class="container mx-auto px-6 max-w-5xl">
      <div class="prose prose-invert prose-xl mx-auto max-w-5xl py-12 blog-content" data-aos="fade-up" data-aos-delay="200" lang="tr"><Content /></div>
    </div>

    {relatedPosts.length > 0 && (
      <section class="container mx-auto px-4 max-w-5xl mt-16 pt-10 border-t border-white/10">
        <h2 class="text-2xl font-serif text-gold-500 mb-6">İlgili Yazılar</h2>
        <div class="grid md:grid-cols-2 gap-5">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="block p-5 rounded-xl bg-slate-900/50 border border-slate-800 hover:border-gold-500/40 transition-colors">
              <p class="text-xs text-slate-500 mb-2">{post.data.category || 'Genel'}</p>
              <h3 class="text-lg text-white font-serif line-clamp-2 mb-2">{post.data.title}</h3>
              <p class="text-sm text-slate-400 line-clamp-2">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="container mx-auto px-4 max-w-4xl mt-16 pt-8 border-t border-white/10 flex justify-between items-center">
      <a href="/blog" class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors">Blog'a Dön</a>
      <ShareButton client:visible title={entry.data.title} url={Astro.url.href} />
    </div>
  </article>
</Layout>
