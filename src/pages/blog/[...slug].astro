---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ShareButton from '../../components/ShareButton';
import InstagramEmbed from '../../components/InstagramEmbed.astro';
import { toAbsoluteUrl, getSiteUrl, legalArticleSchema, faqPageSchema } from '../../lib/seo';
import { getRelatedPosts } from '../../lib/blog';
import { blogMiniFaqs } from '../../content/blog-mini-faqs';
import { FAQAccordion } from '../../components/FAQAccordion';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allPosts = await getCollection('blog');
const relatedPosts = getRelatedPosts(entry, allPosts, 4);
const wordCount = entry.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
const canonicalPath = `/blog/${entry.slug}`;
const canonical = toAbsoluteUrl(canonicalPath, Astro.site);
const imageUrl = toAbsoluteUrl(entry.data.image, Astro.site);

const miniFaqs = blogMiniFaqs[entry.slug] || [];
const miniFaqLd = miniFaqs.length ? faqPageSchema(miniFaqs, canonical) : null;

const articleSchema = legalArticleSchema({
  title: entry.data.title,
  description: entry.data.description,
  url: canonical,
  origin: getSiteUrl(Astro.site).origin,
  image: imageUrl,
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.updatedDate || entry.data.pubDate).toISOString(),
  authorName: entry.data.author || 'Av. Fatih Dişçi',
  section: entry.data.category || 'Genel',
  keywords: entry.data.tags || [],
});
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  canonicalPath={canonicalPath}
  pageType="article"
  enableAOS={true}
  breadcrumbItems={[{ name: 'Blog', href: '/blog' }, { name: entry.data.title, href: canonicalPath }]}
  structuredData={miniFaqLd ? [articleSchema, miniFaqLd] : articleSchema}
  article={{
    publishedTime: entry.data.pubDate.toISOString(),
    modifiedTime: (entry.data.updatedDate || entry.data.pubDate).toISOString(),
    author: entry.data.author || 'Av. Fatih Dişçi',
    section: entry.data.category || 'Genel',
    tags: entry.data.tags || [],
  }}
>
  <article class="py-24 min-h-screen" style="background: var(--bg);">
    <div class="container mx-auto px-4 max-w-4xl mb-12 text-center" data-aos="fade-up">
      <div class="mb-6 flex items-center justify-center gap-4 text-sm flex-wrap">
        <span class="text-gold-500 font-bold px-3 py-1 rounded-full bg-gold-500/10 border border-gold-500/20">{entry.data.category}</span>
        <span style="color: var(--text-3);">•</span>
        <time style="color: var(--text-2);">{entry.data.pubDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span style="color: var(--text-3);">•</span>
        <span style="color: var(--text-2);">{readingTime} dk okuma</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-8 leading-tight font-display" style="color: var(--text);">{entry.data.title}</h1>
      {entry.data.image && <img src={entry.data.image} alt={entry.data.title} width="1280" height="720" loading="eager" fetchpriority="high" decoding="async" class="w-full h-auto object-cover max-h-[500px] rounded-2xl overflow-hidden shadow-2xl border mb-12" style="border-color: var(--border);" />}
    </div>

    <div class="container mx-auto px-6 max-w-5xl">
      <div class="prose prose-invert prose-xl mx-auto max-w-5xl py-12 blog-content" data-aos="fade-up" data-aos-delay="200" lang="tr"><Content /></div>
    </div>

    {entry.data.instagramUrl && (
      <div class="container mx-auto px-4 max-w-5xl mt-12 pt-10 border-t" style="border-color: var(--border);">
        <InstagramEmbed url={entry.data.instagramUrl} />
      </div>
    )}

    {miniFaqs.length > 0 && (
      <section class="container mx-auto px-4 max-w-4xl mt-16 pt-10 border-t" style="border-color: var(--border);" aria-labelledby="mini-faq-title">
        <h2 id="mini-faq-title" class="text-2xl md:text-3xl font-display text-gold-500 mb-6">Sıkça Sorulan Sorular</h2>
        <FAQAccordion client:visible faqs={miniFaqs} />
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="container mx-auto px-4 max-w-5xl mt-16 pt-10 border-t" style="border-color: var(--border);">
        <h2 class="text-2xl font-display text-gold-500 mb-6">İlgili Yazılar</h2>
        <div class="grid md:grid-cols-2 gap-5">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="block p-5 rounded-xl border hover:border-gold-500/40 transition-colors" style="background: var(--card-bg); border-color: var(--border);">
              <p class="text-xs mb-2" style="color: var(--text-3);">{post.data.category || 'Genel'}</p>
              <h3 class="text-lg font-display line-clamp-2 mb-2" style="color: var(--text);">{post.data.title}</h3>
              <p class="text-sm line-clamp-2" style="color: var(--text-2);">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="container mx-auto px-4 max-w-4xl mt-16 pt-8 border-t flex justify-between items-center" style="border-color: var(--border);">
      <a href="/blog" class="inline-flex items-center gap-2 hover:text-gold-500 transition-colors" style="color: var(--text-2);">Blog'a Dön</a>
      <ShareButton client:visible title={entry.data.title} url={Astro.url.href} />
    </div>
  </article>
</Layout>
