---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ShareButton from '../../components/ShareButton';
import InstagramEmbed from '../../components/InstagramEmbed.astro';
import QuickAnswer from '../../components/QuickAnswer.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import { toAbsoluteUrl, getSiteUrl, legalArticleSchema, faqPageSchema } from '../../lib/seo';
import { getRelatedPosts, getServiceForCategory } from '../../lib/blog';
import { blogMiniFaqs } from '../../content/blog-mini-faqs';
import { FAQAccordion } from '../../components/FAQAccordion';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allPosts = await getCollection('blog');
const relatedPosts = getRelatedPosts(entry, allPosts, 4);
const wordCount = entry.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
const canonicalPath = `/blog/${entry.slug}`;
const canonical = toAbsoluteUrl(canonicalPath, Astro.site);
const imageUrl = toAbsoluteUrl(entry.data.image, Astro.site);

const miniFaqs = entry.data.miniFaqs?.length ? entry.data.miniFaqs : (blogMiniFaqs[entry.slug] || []);
const relatedService = getServiceForCategory(entry.data.category);
const miniFaqLd = miniFaqs.length ? faqPageSchema(miniFaqs, canonical) : null;

const articleSchema = legalArticleSchema({
  title: entry.data.title,
  description: entry.data.description,
  url: canonical,
  origin: getSiteUrl(Astro.site).origin,
  image: imageUrl,
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.updatedDate || entry.data.pubDate).toISOString(),
  authorName: entry.data.author || 'Av. Fatih Dişçi',
  section: entry.data.category || 'Genel',
  keywords: entry.data.tags || [],
});
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  canonicalPath={canonicalPath}
  pageType="article"
  enableAOS={true}
  breadcrumbItems={[{ name: 'Blog', href: '/blog' }, { name: entry.data.title, href: canonicalPath }]}
  structuredData={miniFaqLd ? [articleSchema, miniFaqLd] : articleSchema}
  article={{
    publishedTime: entry.data.pubDate.toISOString(),
    modifiedTime: (entry.data.updatedDate || entry.data.pubDate).toISOString(),
    author: entry.data.author || 'Av. Fatih Dişçi',
    section: entry.data.category || 'Genel',
    tags: entry.data.tags || [],
  }}
>
  <article class="post-article">
    <header class="container mx-auto px-4 max-w-3xl text-center post-header" data-aos="fade-up">
      <div class="post-meta">
        <span class="post-category">{entry.data.category}</span>
        <span class="post-meta-sep" aria-hidden="true">·</span>
        <time class="post-meta-item">{entry.data.pubDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span class="post-meta-sep" aria-hidden="true">·</span>
        <span class="post-meta-item">{readingTime} dk okuma</span>
      </div>
      <h1 class="post-h1">{entry.data.title}</h1>
    </header>

    {entry.data.image && (
      <div class="container mx-auto px-4 max-w-4xl mb-12" data-aos="fade-up" data-aos-delay="100">
        <img
          src={entry.data.image}
          alt={entry.data.imageAlt || entry.data.title}
          width="1280"
          height="720"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="post-hero-image"
        />
      </div>
    )}

    {entry.data.quickAnswer && (
      <div class="container mx-auto px-6 max-w-3xl" data-aos="fade-up" data-aos-delay="150">
        <QuickAnswer highlights={entry.data.quickAnswer.highlights}>
          <p set:html={entry.data.quickAnswer.intro} />
        </QuickAnswer>
      </div>
    )}

    <div class="container mx-auto px-6 max-w-3xl">
      <div class="prose prose-lg mx-auto py-6 blog-content" data-aos="fade-up" data-aos-delay="200" lang="tr">
        <Content />
      </div>
    </div>

    {entry.data.instagramUrl && (
      <div class="container mx-auto px-4 max-w-3xl mt-12 pt-10 post-divider">
        <InstagramEmbed url={entry.data.instagramUrl} />
      </div>
    )}

    {relatedService && (
      <aside class="container mx-auto px-4 max-w-3xl mt-12 not-prose" aria-label="İlgili Çalışma Alanı">
        <a href={`/calisma-alanlarimiz/${relatedService.slug}`} class="related-service-cta cursor-pointer">
          <div class="related-service-cta-body">
            <span class="related-service-cta-eyebrow">İlgili Çalışma Alanı</span>
            <span class="related-service-cta-title">{relatedService.title}</span>
            <span class="related-service-cta-text">
              Bu konuda detaylı bilgi ve hukuki süreç adımları için ilgili çalışma alanı sayfasını inceleyebilirsiniz.
            </span>
          </div>
          <span class="related-service-cta-arrow" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </span>
        </a>
      </aside>
    )}

    <div class="container mx-auto px-4 max-w-3xl mt-16 pt-10 post-divider">
      <AuthorBio />
    </div>

    {miniFaqs.length > 0 && (
      <section class="container mx-auto px-4 max-w-3xl mt-16 pt-10 post-divider" aria-labelledby="mini-faq-title">
        <h2 id="mini-faq-title" class="post-section-title"><span class="post-section-title-italic">Sıkça</span> Sorulan Sorular</h2>
        <FAQAccordion client:visible faqs={miniFaqs} />
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="container mx-auto px-4 max-w-4xl mt-16 pt-10 post-divider">
        <h2 class="post-section-title"><span class="post-section-title-italic">İlgili</span> Yazılar</h2>
        <div class="grid md:grid-cols-2 gap-5 mt-8">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="related-post cursor-pointer">
              <p class="related-post-cat">{post.data.category || 'Genel'}</p>
              <h3 class="related-post-title">{post.data.title}</h3>
              <p class="related-post-desc">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="container mx-auto px-4 max-w-3xl mt-16 pt-8 post-divider post-footer-row">
      <a href="/blog" class="post-back-link cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
        </svg>
        Blog'a Dön
      </a>
      <ShareButton client:visible title={entry.data.title} url={Astro.url.href} />
    </div>
  </article>
</Layout>

<style>
  .post-article {
    background: var(--bg-base);
    padding: clamp(2.5rem, 6vw, 4.5rem) 0 clamp(4rem, 9vw, 6rem);
    min-height: 100vh;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    margin-bottom: 1.75rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
  }

  .post-category {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    background: var(--brand-soft);
    color: var(--brand-deep);
    border: 1px solid var(--border-soft);
    line-height: 1;
  }

  .post-meta-sep { color: var(--ink-faint); }

  .post-meta-item { color: var(--ink-muted); }

  .post-h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    font-size: var(--text-hero);
    line-height: 1.05;
    letter-spacing: -0.022em;
    color: var(--ink-strong);
    margin: 0;
  }

  .post-hero-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 520px;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .post-divider {
    border-top: 1px solid var(--border-soft);
  }

  .post-section-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.75rem;
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--ink-strong);
    margin-bottom: 1rem;
  }
  .post-section-title-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .related-post {
    display: block;
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.25rem 1.5rem;
    transition: transform 280ms ease, box-shadow 280ms ease, border-color 280ms ease;
  }
  .related-post:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--brand);
  }
  .related-post-cat {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.5rem;
  }
  .related-post-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.0625rem;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--ink-strong);
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 200ms ease;
  }
  .related-post:hover .related-post-title { color: var(--brand-deep); }
  .related-post-desc {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--ink-default);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--brand-deep);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: color 200ms ease, border-color 200ms ease;
  }
  .post-back-link:hover {
    color: var(--ink-strong);
    border-bottom-color: currentColor;
  }
  .post-back-link svg {
    transition: transform 220ms ease;
  }
  .post-back-link:hover svg {
    transform: translateX(-3px);
  }

  .related-service-cta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-left: 3px solid var(--brand);
    border-radius: var(--radius-lg);
    transition: border-color 240ms ease, transform 240ms ease, box-shadow 240ms ease;
  }
  .related-service-cta:hover {
    border-color: var(--brand-deep);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .related-service-cta-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
    min-width: 0;
  }
  .related-service-cta-eyebrow {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--brand-deep);
  }
  .related-service-cta-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.25rem;
    line-height: 1.2;
    color: var(--ink-strong);
  }
  .related-service-cta-text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--ink-default);
  }
  .related-service-cta-arrow {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--brand-soft);
    color: var(--brand-deep);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 240ms ease, transform 240ms ease;
  }
  .related-service-cta:hover .related-service-cta-arrow {
    background: var(--brand);
    color: var(--bg-elevated);
    transform: translateX(3px);
  }
</style>
