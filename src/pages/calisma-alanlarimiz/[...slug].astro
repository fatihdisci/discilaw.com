---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { FAQAccordion } from '../../components/FAQAccordion';
import { ServiceIcon } from '../../components/ServiceIcon';
import { toAbsoluteUrl } from '../../lib/seo';

export async function getStaticPaths() {
  const serviceEntries = await getCollection('services');
  return serviceEntries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const canonicalPath = `/calisma-alanlarimiz/${entry.slug}`;

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((post) => {
    const cat = (post.data.category || '').toLowerCase();
    const title = entry.data.title.toLowerCase();
    return cat === title || cat.includes(title) || title.includes(cat) || post.data.tags?.some((tag) => tag.toLowerCase() === title);
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: `${entry.data.title} - Dişçi Hukuk Bürosu`,
  description: entry.data.description,
  url: toAbsoluteUrl(canonicalPath, Astro.site),
  provider: {
    '@id': `${toAbsoluteUrl('/', Astro.site)}#organization`,
    '@type': 'LegalService',
    name: 'Dişçi Hukuk Bürosu',
    telephone: '+905077247735',
    address: { '@type': 'PostalAddress', addressLocality: 'İzmir', addressCountry: 'TR' },
  },
  areaServed: 'İzmir, Türkiye',
};

const faqSchema = entry.data.faqs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: entry.data.faqs.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })),
    }
  : null;
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  enableAOS={true}
  breadcrumbItems={[{ name: 'Çalışma Alanlarımız', href: '/calisma-alanlarimiz' }, { name: entry.data.title, href: canonicalPath }]}
  structuredData={faqSchema ? [serviceSchema, faqSchema] : serviceSchema}
>
  <article class="py-24 bg-slate-950 min-h-screen">
    <div class="container mx-auto px-4 max-w-4xl mb-12 text-center" data-aos="fade-up">
      <div class="mb-6 flex justify-center"><ServiceIcon client:visible slug={entry.slug} size={64} className="text-gold-500" /></div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight font-serif">{entry.data.title}</h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto">{entry.data.description}</p>
    </div>
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="prose prose-invert prose-lg mx-auto max-w-4xl py-12 service-content" data-aos="fade-up" data-aos-delay="200" lang="tr">
        <Content />
        {entry.data.faqs?.length > 0 && (
          <div class="mt-12 not-prose">
            <h2 class="text-3xl font-serif text-gold-500 mb-6">Sıkça Sorulan Sorular</h2>
            <FAQAccordion client:visible faqs={entry.data.faqs} />
          </div>
        )}
      </div>
    </div>

    {relatedPosts.length > 0 && (
      <div class="container mx-auto px-4 max-w-4xl mt-20 pt-10 border-t border-white/10">
        <h3 class="text-2xl font-serif text-gold-500 mb-8">{entry.data.title} Hakkında Güncel Makaleler</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block bg-slate-900/50 border border-slate-800 rounded-xl p-5 hover:border-gold-500/30 transition-all hover:bg-slate-900 duration-300">
              <time class="text-xs text-slate-500">{post.data.pubDate.toLocaleDateString('tr-TR')}</time>
              <h4 class="text-md font-bold text-slate-200 group-hover:text-gold-400 mb-2 font-serif line-clamp-2">{post.data.title}</h4>
              <p class="text-xs text-slate-400 line-clamp-2">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</Layout>
