---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { FAQAccordion } from '../../components/FAQAccordion';
import { ServiceIcon } from '../../components/ServiceIcon';
import QuickAnswer from '../../components/QuickAnswer.astro';
import { toAbsoluteUrl, getSiteUrl, serviceSchema, faqPageSchema } from '../../lib/seo';
import { quickAnswers } from '../../content/quick-answers';

export async function getStaticPaths() {
  const serviceEntries = await getCollection('services');
  return serviceEntries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const canonicalPath = `/calisma-alanlarimiz/${entry.slug}`;

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((post) => {
    const cat = (post.data.category || '').toLowerCase();
    const title = entry.data.title.toLowerCase();
    return cat === title || cat.includes(title) || title.includes(cat) || post.data.tags?.some((tag) => tag.toLowerCase() === title);
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const pageUrl = toAbsoluteUrl(canonicalPath, Astro.site);
const origin = getSiteUrl(Astro.site).origin;

const serviceLd = serviceSchema({
  title: entry.data.title,
  description: entry.data.description,
  url: pageUrl,
  origin,
});

const faqLd = entry.data.faqs?.length ? faqPageSchema(entry.data.faqs, pageUrl) : null;

const quickAnswer = quickAnswers[entry.slug];
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  enableAOS={true}
  breadcrumbItems={[{ name: 'Çalışma Alanlarımız', href: '/calisma-alanlarimiz' }, { name: entry.data.title, href: canonicalPath }]}
  structuredData={faqLd ? [serviceLd, faqLd] : serviceLd}
>
  <article class="py-24 min-h-screen" style="background: var(--bg);">
    <div class="container mx-auto px-4 max-w-4xl mb-12 text-center" data-aos="fade-up">
      <div class="mb-6 flex justify-center"><ServiceIcon client:visible slug={entry.slug} size={64} className="text-gold-500" /></div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight font-display" style="color: var(--text);">{entry.data.title}</h1>
      <p class="text-xl max-w-2xl mx-auto" style="color: var(--text-2);">{entry.data.description}</p>
    </div>
    {quickAnswer && (
      <div class="container mx-auto px-6 max-w-4xl" data-aos="fade-up" data-aos-delay="100">
        <QuickAnswer highlights={quickAnswer.highlights}>
          <p set:html={quickAnswer.intro} />
        </QuickAnswer>
      </div>
    )}

    <div class="container mx-auto px-6 max-w-4xl">
      <div class="prose prose-invert prose-lg mx-auto max-w-4xl py-12 service-content" data-aos="fade-up" data-aos-delay="200" lang="tr">
        <Content />
        {entry.data.faqs?.length > 0 && (
          <div class="mt-12 not-prose">
            <h2 class="text-3xl font-display text-gold-500 mb-6">Sıkça Sorulan Sorular</h2>
            <FAQAccordion client:visible faqs={entry.data.faqs} />
          </div>
        )}
      </div>
    </div>

    {relatedPosts.length > 0 && (
      <div class="container mx-auto px-4 max-w-4xl mt-20 pt-10 border-t" style="border-color: var(--border);">
        <h3 class="text-2xl font-display text-gold-500 mb-8">{entry.data.title} Hakkında Güncel Makaleler</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block border rounded-xl p-5 hover:border-gold-500/30 transition-all duration-300" style="background: var(--card-bg); border-color: var(--border);">
              <time class="text-xs" style="color: var(--text-3);">{post.data.pubDate.toLocaleDateString('tr-TR')}</time>
              <h4 class="text-md font-bold group-hover:text-gold-400 mb-2 font-display line-clamp-2" style="color: var(--text);">{post.data.title}</h4>
              <p class="text-xs line-clamp-2" style="color: var(--text-2);">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</Layout>
