---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { FAQAccordion } from '../../components/FAQAccordion';
import { ServiceIcon } from '../../components/ServiceIcon';
import QuickAnswer from '../../components/QuickAnswer.astro';
import { toAbsoluteUrl, getSiteUrl, serviceSchema, faqPageSchema } from '../../lib/seo';
import { quickAnswers } from '../../content/quick-answers';

export async function getStaticPaths() {
  const serviceEntries = await getCollection('services');
  return serviceEntries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const canonicalPath = `/calisma-alanlarimiz/${entry.slug}`;

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((post) => {
    const cat = (post.data.category || '').toLowerCase();
    const title = entry.data.title.toLowerCase();
    return cat === title || cat.includes(title) || title.includes(cat) || post.data.tags?.some((tag) => tag.toLowerCase() === title);
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const pageUrl = toAbsoluteUrl(canonicalPath, Astro.site);
const origin = getSiteUrl(Astro.site).origin;

const serviceLd = serviceSchema({
  title: entry.data.title,
  description: entry.data.description,
  url: pageUrl,
  origin,
});

const faqLd = entry.data.faqs?.length ? faqPageSchema(entry.data.faqs, pageUrl) : null;

const quickAnswer = quickAnswers[entry.slug];
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  enableAOS={true}
  breadcrumbItems={[{ name: 'Çalışma Alanlarımız', href: '/calisma-alanlarimiz' }, { name: entry.data.title, href: canonicalPath }]}
  structuredData={faqLd ? [serviceLd, faqLd] : serviceLd}
>
  <article class="service-article">
    <div class="container mx-auto px-4 max-w-4xl mb-12 text-center" data-aos="fade-up">
      <div class="service-icon-hero">
        <ServiceIcon client:visible slug={entry.slug} size={48} className="service-icon-hero-svg" />
      </div>
      <h1 class="service-h1">{entry.data.title}</h1>
      <p class="service-lede">{entry.data.description}</p>
    </div>

    {quickAnswer && (
      <div class="container mx-auto px-6 max-w-4xl" data-aos="fade-up" data-aos-delay="100">
        <QuickAnswer highlights={quickAnswer.highlights}>
          <p set:html={quickAnswer.intro} />
        </QuickAnswer>
      </div>
    )}

    <div class="container mx-auto px-6 max-w-4xl">
      <div class="prose prose-lg mx-auto max-w-4xl py-12 service-content" data-aos="fade-up" data-aos-delay="200" lang="tr">
        <Content />
        {entry.data.faqs?.length > 0 && (
          <div class="mt-12 not-prose">
            <h2 class="service-section-title"><span class="service-section-title-italic">Sıkça</span> Sorulan Sorular</h2>
            <FAQAccordion client:visible faqs={entry.data.faqs} />
          </div>
        )}
      </div>
    </div>

    {relatedPosts.length > 0 && (
      <div class="container mx-auto px-4 max-w-4xl mt-20 pt-10 related-section">
        <h3 class="service-section-title">{entry.data.title} Hakkında <span class="service-section-title-italic">güncel</span> makaleler</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="related-card group cursor-pointer">
              <time class="related-card-date">{post.data.pubDate.toLocaleDateString('tr-TR')}</time>
              <h4 class="related-card-title">{post.data.title}</h4>
              <p class="related-card-desc">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</Layout>

<style>
  .service-article {
    background: var(--bg-base);
    padding: clamp(3rem, 7vw, 5rem) 0 clamp(4rem, 9vw, 6rem);
    min-height: 100vh;
  }

  .service-icon-hero {
    margin: 0 auto 1.75rem;
    width: 84px;
    height: 84px;
    border-radius: var(--radius-lg);
    background: var(--brand-soft);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  :global(.service-icon-hero-svg) {
    color: var(--brand-deep);
    stroke-width: 1.5;
  }

  .service-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-h1);
    line-height: 1.05;
    letter-spacing: -0.022em;
    color: var(--ink-strong);
    margin-bottom: 1.5rem;
  }

  .service-lede {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--ink-default);
    max-width: 36rem;
    margin: 0 auto;
  }

  .service-section-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.75rem;
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--ink-strong);
    margin-bottom: 1.5rem;
  }
  .service-section-title-italic {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    color: var(--brand-deep);
  }

  .related-section {
    border-top: 1px solid var(--border-soft);
  }

  .related-card {
    display: block;
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.25rem 1.5rem;
    transition: transform 280ms ease, box-shadow 280ms ease, border-color 280ms ease;
  }
  .related-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--brand);
  }
  .related-card-date {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: block;
    margin-bottom: 0.5rem;
  }
  .related-card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--ink-strong);
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .related-card:hover .related-card-title { color: var(--brand-deep); }
  .related-card-desc {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--ink-default);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
