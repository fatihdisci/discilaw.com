---
import Layout from '../../layouts/Layout.astro';
import NoticePayCalculator from '../../components/calculators/NoticePayCalculator.jsx';
import { toAbsoluteUrl, getSiteUrl, webApplicationSchema, howToSchema } from '../../lib/seo';

const canonicalPath = '/hesaplama-araclari/ihbar-tazminati';
const pageUrl = toAbsoluteUrl(canonicalPath, Astro.site);
const origin = getSiteUrl(Astro.site).origin;

const appLd = webApplicationSchema({
  name: 'İhbar Tazminatı Hesaplama Aracı',
  description: 'Hizmet süresi ve vergi dilimine göre güncel ihbar tazminatı hesaplama.',
  url: pageUrl,
  origin,
});

const howToLd = howToSchema({
  name: 'İhbar Tazminatı Nasıl Hesaplanır?',
  description: 'İhbar tazminatı hesaplama aracını kullanmak için izlenecek adımlar.',
  url: pageUrl,
  steps: [
    { name: 'Hizmet sürenizi girin', text: 'Toplam çalışma sürenizi yıl/ay olarak yazın.' },
    { name: 'Brüt ücretinizi girin', text: 'Aylık brüt ücretinizi yazın.' },
    { name: 'Vergi dilimini seçin', text: 'Yıl içindeki kümülatif vergi dilimini belirleyin.' },
    { name: 'Hesaplama yapın', text: 'İhbar süresine denk gelen ücret tutarı net olarak hesaplanır.' },
  ],
});
---

<Layout
  title="İhbar Tazminatı Hesaplama"
  description="İhbar tazminatı hesaplama aracı. Hizmet sürenize ve vergi diliminize göre ihbar tazminatınızı hesaplayın."
  canonicalPath={canonicalPath}
  enableAOS={true}
  structuredData={[appLd, howToLd]}
>
    <section class="calc-page">
        <div class="container mx-auto px-4">
            <div class="calc-page-header" data-aos="fade-up">
                <a href="/hesaplama-araclari" class="calc-back-link cursor-pointer">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                    Tüm Hesaplama Araçları
                </a>
                <h1 class="calc-page-title">
                    <span class="calc-page-title-italic">İhbar</span> Tazminatı Hesaplama
                </h1>
                <p class="calc-page-lede">
                    Hizmet sürenize ve vergi diliminize göre ihbar tazminatınızı hesaplayın.
                </p>
            </div>

            <div class="max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
                <NoticePayCalculator client:load />
            </div>

            <div class="max-w-3xl mx-auto mt-16" data-aos="fade-up" data-aos-delay="200">
                <div class="calc-info-card">
                    <h2 class="calc-info-title">İhbar Tazminatı Hakkında</h2>
                    <div class="calc-info-body">
                        <p>
                            <strong>İhbar tazminatı</strong>, iş sözleşmesinin feshi sırasında
                            bildirim sürelerine uyulmaması halinde, karşı tarafa ödenmesi gereken bir tazminattır.
                            Hem işçi hem de işveren bu yükümlülük altındadır.
                        </p>
                        <h3 class="calc-info-h3">Yasal İhbar Süreleri:</h3>
                        <ul class="calc-info-list">
                            <li>6 aydan az çalışma: <strong>2 hafta</strong></li>
                            <li>6 ay - 1.5 yıl arası çalışma: <strong>4 hafta</strong></li>
                            <li>1.5 yıl - 3 yıl arası çalışma: <strong>6 hafta</strong></li>
                            <li>3 yıldan fazla çalışma: <strong>8 hafta</strong></li>
                        </ul>
                        <div class="calc-info-callout">
                            <p>
                                <strong>Önemli:</strong> Bu hesaplama aracı yalnızca bilgilendirme amaçlıdır.
                                Kesin sonuçlar ve hukuki değerlendirme için mutlaka bir avukata danışmanızı öneririz.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .calc-page {
        background: var(--bg-base);
        padding: clamp(3rem, 7vw, 5rem) 0 clamp(4rem, 9vw, 6rem);
    }
    .calc-page-header { text-align: center; margin-bottom: 3rem; }

    .calc-back-link {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-family: var(--font-sans); font-weight: 500; font-size: 0.875rem;
        color: var(--ink-muted); margin-bottom: 1.5rem;
        border-bottom: 1px solid transparent; padding-bottom: 1px;
        transition: color 200ms ease, border-color 200ms ease;
    }
    .calc-back-link:hover { color: var(--brand-deep); border-bottom-color: currentColor; }
    .calc-back-link svg { transition: transform 220ms ease; }
    .calc-back-link:hover svg { transform: translateX(-3px); }

    .calc-page-title {
        font-family: var(--font-display); font-weight: 500;
        font-size: var(--text-h1); line-height: 1.05; letter-spacing: -0.022em;
        color: var(--ink-strong); margin-bottom: 1.25rem;
    }
    .calc-page-title-italic {
        font-style: italic; font-weight: 400;
        font-variation-settings: "SOFT" 100, "opsz" 144;
        color: var(--brand-deep);
    }
    .calc-page-lede {
        max-width: 36rem; margin: 0 auto;
        font-family: var(--font-sans); font-weight: 300;
        font-size: 1.125rem; line-height: 1.6; color: var(--ink-default);
    }

    .calc-info-card {
        background: var(--bg-elevated);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-xl);
        padding: 2rem;
    }
    @media (min-width: 768px) { .calc-info-card { padding: 2.5rem; } }
    .calc-info-title {
        font-family: var(--font-display); font-weight: 500;
        font-size: 1.625rem; line-height: 1.15; letter-spacing: -0.018em;
        color: var(--ink-strong); margin-bottom: 1.25rem;
    }
    .calc-info-body {
        font-family: var(--font-sans); font-size: 0.9375rem;
        line-height: 1.65; color: var(--ink-default);
    }
    .calc-info-body p { margin-bottom: 1rem; }
    .calc-info-body strong { color: var(--ink-strong); font-weight: 600; }
    .calc-info-h3 {
        font-family: var(--font-display); font-weight: 600; font-size: 1.0625rem;
        color: var(--ink-strong); margin-top: 1.5rem; margin-bottom: 0.5rem;
        letter-spacing: -0.015em;
    }
    .calc-info-list {
        list-style: disc; padding-left: 1.25rem; margin-bottom: 1rem;
    }
    .calc-info-list li { margin-bottom: 0.4rem; }
    .calc-info-list li::marker { color: var(--brand); }
    .calc-info-list strong { color: var(--brand-deep); }

    .calc-info-callout {
        margin-top: 1.5rem;
        background: var(--accent-soft);
        border: 1px solid rgba(200, 98, 58, 0.22);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius-md);
        padding: 1rem 1.25rem;
    }
    .calc-info-callout p {
        font-family: var(--font-sans); font-size: 0.875rem;
        line-height: 1.6; color: var(--ink-strong); margin: 0;
    }
    .calc-info-callout strong { color: var(--accent); }
</style>
