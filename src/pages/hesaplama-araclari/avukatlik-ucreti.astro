---
import Layout from '../../layouts/Layout.astro';
import AttorneyFeeCalculator from '../../components/calculators/AttorneyFeeCalculator';
import { toAbsoluteUrl, getSiteUrl, webApplicationSchema, howToSchema } from '../../lib/seo';

const canonicalPath = '/hesaplama-araclari/avukatlik-ucreti';
const pageUrl = toAbsoluteUrl(canonicalPath, Astro.site);
const origin = getSiteUrl(Astro.site).origin;

const appLd = webApplicationSchema({
  name: 'Avukatlık Asgari Ücret Hesaplama Aracı',
  description: '2025-2026 dönemi AAÜT tarifesine göre dava ve icra takipleri için asgari avukatlık ücreti hesaplama.',
  url: pageUrl,
  origin,
});

const howToLd = howToSchema({
  name: 'Avukatlık Asgari Ücreti Nasıl Hesaplanır?',
  description: 'AAÜT tarifesi üzerinden avukatlık ücreti hesaplama adımları.',
  url: pageUrl,
  steps: [
    { name: 'Dava türünü seçin', text: 'Hukuk, ceza, idari, icra dava ve takip türlerinden uygun olanı seçin.' },
    { name: 'Dava değerini girin', text: 'Konusu para olan davalarda dava değerini yazın.' },
    { name: 'Yargı yerini seçin', text: 'Görevli mahkeme veya icra dairesi türünü belirleyin.' },
    { name: 'Hesaplama yapın', text: 'AAÜT 2025-2026 tarifesine göre asgari ücret hesaplanır.' },
  ],
});
---

<Layout
  title="Avukatlık Asgari Ücret Hesaplama 2025-2026"
  description="En güncel AAÜT tarifesine göre dava ve icra takipleri için asgari avukatlık ücreti hesaplama robotu."
  canonicalPath={canonicalPath}
  structuredData={[appLd, howToLd]}
>
    <section class="py-20 md:py-32">
        <div class="container mx-auto px-4">
            <!-- Header -->
            <div class="text-center mb-12" data-aos="fade-up">
                <a href="/hesaplama-araclari" class="inline-flex items-center hover:text-gold-500 transition-colors mb-6" style="color: var(--text-2);">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Tüm Hesaplama Araçları
                </a>
                <h1 class="text-4xl md:text-5xl font-light mb-6 font-display" style="color: var(--text);">Avukatlık Asgari Ücret Hesaplama</h1>
                <p class="text-xl max-w-3xl mx-auto" style="color: var(--text-2);">
                    2025-2026 dönemi Resmi Gazete'de yayımlanan Avukatlık Asgari Ücret Tarifesi (AAÜT) uyarınca güncel hesaplama yapın.
                </p>
            </div>

            <!-- Calculator Component -->
            <div class="max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
                <AttorneyFeeCalculator client:load />
            </div>

            <!-- Info Sections -->
            <div class="max-w-3xl mx-auto mt-16" data-aos="fade-up" data-aos-delay="200">
                <div class="rounded-2xl p-8 border" style="background: var(--bg-2); border-color: var(--border);">
                    <h3 class="text-2xl md:text-3xl font-bold mb-6 font-display" style="color: var(--text);">AAÜT Hakkında</h3>
                    <p class="leading-relaxed mb-10 text-lg" style="color: var(--text-2);">
                        Avukatlık Asgari Ücret Tarifesi (AAÜT), avukatların sundukları hukuki hizmetler karşılığında alabilecekleri en alt ücret sınırını belirleyen resmi bir belgedir. Her yıl Türkiye Barolar Birliği tarafından hazırlanır ve Adalet Bakanlığı onayıyla Resmi Gazete'de yayımlanır.
                    </p>

                    <div class="grid md:grid-cols-2 gap-6 text-left mb-10">
                        <div class="p-6 rounded-2xl border hover:border-gold-500/30 transition-colors" style="background: var(--bg-3); border-color: var(--border);">
                            <h4 class="font-bold mb-3 text-lg" style="color: var(--text);">Maktu Ücretler</h4>
                            <p class="leading-relaxed" style="color: var(--text-2);">Mahkeme türüne göre belirlenmiş, dava değerinden bağımsız sabit tutarlardır.</p>
                        </div>
                        <div class="p-6 rounded-2xl border hover:border-gold-500/30 transition-colors" style="background: var(--bg-3); border-color: var(--border);">
                            <h4 class="font-bold mb-3 text-lg" style="color: var(--text);">Nispi Oranlar</h4>
                            <p class="leading-relaxed" style="color: var(--text-2);">Konusu para olan davalarda, dava değeri üzerinden kademeli olarak hesaplanan oranlardır.</p>
                        </div>
                    </div>

                    <div class="bg-gold-500/5 border border-gold-500/20 rounded-2xl p-6 md:p-8">
                        <p class="text-gold-500/90 leading-relaxed">
                            <strong class="text-gold-500 block mb-2">Önemli Bilgi</strong>
                            Belirlenen bu tutarlar yasal asgari sınırlardır. Avukat ile müvekkil arasındaki ücret sözleşmesi, davanın zorluğu ve harcanacak mesaiye göre bu tutarların üzerinde kararlaştırılabilir.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
