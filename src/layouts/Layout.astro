---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { WhatsAppButton } from '../components/WhatsAppButton';
import { buildSeoMeta, organizationSchema } from '../lib/seo';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  pageType?: 'website' | 'article';
  breadcrumbItems?: { name: string; href: string }[];
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  showBreadcrumbs?: boolean;
  enableAOS?: boolean;
}

const {
  title,
  description,
  image,
  canonicalPath,
  pageType = 'website',
  breadcrumbItems,
  structuredData,
  showBreadcrumbs = true,
  enableAOS = false,
} = Astro.props;

const seo = buildSeoMeta({ title, description, image, canonicalPath, type: pageType }, Astro.url.pathname, Astro.site);
const baseSchema = organizationSchema(Astro.site);
const pageSchemas = Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [];
---

<!doctype html>
<html lang="tr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="GJ-zWmoDnXkoQ1G8DNUsCntcfR3ExIZjJaG9kyni2pE" />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />

    <meta property="og:type" content={seo.type} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.image} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={seo.canonical} />
    <meta property="twitter:title" content={seo.title} />
    <meta property="twitter:description" content={seo.description} />
    <meta property="twitter:image" content={seo.image} />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-E9QFS635LP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-E9QFS635LP');
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" /></noscript>

    {enableAOS && <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />}

    <script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="bg-slate-950 text-slate-300 selection:bg-gold-500/30 selection:text-gold-200 antialiased font-sans pt-32 md:pt-40 flex flex-col min-h-screen">
    <Navbar />

    <main class="flex-grow">
      {showBreadcrumbs && <Breadcrumbs title={title} items={breadcrumbItems} />}
      <slot />
    </main>

    <Footer />

    <WhatsAppButton client:idle />

    {enableAOS && <script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>}
    {enableAOS && (
      <script is:inline>
        AOS.init({ duration: 800, once: true });
      </script>
    )}
  </body>
</html>
