# Keystatic Cloud (primary)
KEYSTATIC_CLOUD_PROJECT=replace-with-your-keystatic-cloud-project-id

# Optional fallback: Keystatic GitHub mode
# (Only needed if you later switch storage.kind to "github")
KEYSTATIC_SECRET=replace-with-a-random-secret-at-least-32-characters
KEYSTATIC_GITHUB_CLIENT_ID=replace-with-github-oauth-app-client-id
KEYSTATIC_GITHUB_CLIENT_SECRET=replace-with-github-oauth-app-client-secret
